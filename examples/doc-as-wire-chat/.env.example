# Copy this file to `.env` (gitignored) and fill in your key to enable S5 (real
# inference). With no key, the worker falls back to the echo stream, so S1-S4 run
# with zero setup.
#
# The key belongs to the worker process: that is the role that runs the model. The
# relay and the thin client never see it. Get a key at https://aistudio.google.com/apikey

GEMINI_API_KEY=

# Optional. Defaults to gemini-3.5-flash (what apps/zhongwen uses).
# GEMINI_MODEL=gemini-3.5-flash
