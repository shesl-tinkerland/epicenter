{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the Fuji main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:event:default",
		"deep-link:default",
		{
			"identifier": "opener:allow-open-url",
			"allow": [
				{ "url": "http://localhost:8787/*" },
				{ "url": "https://api.epicenter.so/*" }
			]
		}
	]
}
