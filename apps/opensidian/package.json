{
	"name": "opensidian",
	"description": "Local-first note-taking app with a built-in bash terminal and real-time sync",
	"private": true,
	"version": "0.0.2",
	"type": "module",
	"exports": {
		".": "./opensidian.ts",
		"./browser": "./opensidian.browser.ts",
		"./project": "./project.ts"
	},
	"scripts": {
		"dev": "bun run dev:local",
		"dev:local": "vite dev",
		"build": "vite build",
		"deploy": "wrangler deploy",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"test": "if find src -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.spec.ts' | grep -q .; then bun test; fi",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check": "bun run typecheck"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.1",
		"@epicenter/app-shell": "workspace:*",
		"@epicenter/auth": "workspace:*",
		"@epicenter/client": "workspace:*",
		"@epicenter/constants": "workspace:*",
		"@epicenter/field": "workspace:*",
		"@epicenter/skills": "workspace:*",
		"@epicenter/svelte": "workspace:*",
		"@tanstack/ai": "catalog:",
		"@tanstack/ai-anthropic": "catalog:",
		"@tanstack/ai-client": "^0.16.3",
		"@tanstack/ai-svelte": "^0.13.4",
		"arktype": "catalog:",
		"better-auth": "catalog:",
		"mode-watcher": "^1.1.0",
		"typebox": "catalog:",
		"wellcrafted": "catalog:",
		"y-indexeddb": "catalog:"
	},
	"devDependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.41.0",
		"@epicenter/filesystem": "workspace:*",
		"@epicenter/ui": "workspace:*",
		"@epicenter/vite-config": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@lezer/highlight": "^1.2.3",
		"@lucide/svelte": "catalog:",
		"@replit/codemirror-vim": "^6.3.0",
		"@sveltejs/adapter-static": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/bun": "catalog:",
		"just-bash": "^2.9.7",
		"shiki": "^3.7.0",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"svelte-sonner": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-node-polyfills": "^0.26.0",
		"y-codemirror.next": "^0.3.5",
		"yjs": "catalog:"
	},
	"license": "AGPL-3.0-or-later"
}
