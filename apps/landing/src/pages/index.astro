---
import { VERSION } from '@epicenter/constants/versions';
import {
	Calendar as CalendarIcon,
	Folder as FolderIcon,
	Image as ImageIcon,
	MessageCircle as MessageCircleIcon,
	Music as MusicIcon,
} from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const year = new Date().getFullYear();
const releasesUrl = 'https://github.com/EpicenterHQ/epicenter/releases/latest';
const githubUrl = 'https://github.com/EpicenterHQ/epicenter';
const discordUrl = 'https://go.epicenter.so/discord';
---

<BaseLayout
	title="Epicenter: Apps come and go. Your files shouldn't."
	description="Epicenter apps save everything you make as ordinary files in a folder on your computer, so what matters to you outlives every app that made it. Start with Whispering, a free speech-to-text app for macOS, Windows, and Linux."
>
	<Fragment slot="head">
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..500&display=swap"
			rel="stylesheet"
		/>
	</Fragment>

	<main class="page">
		<!-- Nav: one quiet door for developers, nothing more -->
		<nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
			<a href="/" class="font-display text-xl font-semibold tracking-tight"
				>Epicenter</a
			>
			<div class="flex items-center gap-6 text-sm">
				<a class="nav-link" href="/whispering">Whispering</a>
				<a class="nav-link" href="/blog">Blog</a>
				<a class="nav-link" href={githubUrl}>GitHub</a>
				<a class="nav-link hidden sm:inline" href={discordUrl}>Discord</a>
			</div>
		</nav>

		<!-- Screen 1: The superpower -->
		<header
			class="mx-auto flex min-h-[92svh] max-w-4xl flex-col items-center justify-center px-6 pb-24 pt-10 text-center"
		>
			<h1 class="font-display hero-step text-balance">Talk instead of type.</h1>
			<p class="hero-step sub mx-auto mt-7 max-w-2xl">
				Whispering is a free speech-to-text app for your computer. Hold a key,
				say it, and the words land wherever your cursor is: email, doc, chat,
				anything.
			</p>
			<div
				class="hero-step mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
			>
				<a class="cta cta-solid" data-download href={releasesUrl}>
					Download Whispering, free
				</a>
				<a class="cta cta-quiet" href="#demo">Watch it work (20 seconds)</a>
			</div>
			<p class="hero-step fineprint mt-5">
				Free and open source. <a class="quiet-link" href={releasesUrl}
					>macOS, Windows, and Linux.</a
				>
				<a class="quiet-link" href="/whispering">More about Whispering</a>
			</p>

			<!-- The demo: a simulated screen built from shipped behavior only -->
			<figure id="demo" class="hero-step mt-14 w-full max-w-xl text-left">
				<div class="demo-window">
					<div class="demo-titlebar">
						<span class="demo-dot"></span>
						<span class="demo-dot"></span>
						<span class="demo-dot"></span>
						<span class="demo-title">New Message</span>
					</div>
					<div class="demo-field"><span>To:</span> Sam</div>
					<div class="demo-field"><span>Subject:</span> Running late</div>
					<p class="demo-body" data-typed>
						Just left the office, traffic is slow on the bridge. I should be
						there by seven. Want me to grab dinner on the way?
					</p>
					<div class="demo-hint">
						<kbd>alt</kbd>
						<kbd>space</kbd>
						<span>Hold to talk. Release, and the words type themselves.</span>
					</div>
				</div>
				<figcaption class="fineprint mt-3 text-center">
					Simulated screen. The real flow is the same: hold the shortcut, talk,
					release.
				</figcaption>
			</figure>
		</header>

		<!-- Screen 2: The gag -->
		<section class="band">
			<div class="mx-auto max-w-3xl px-6 py-28 text-center md:py-36">
				<div class="reveal">
					<button id="export-button" type="button" class="gag-btn font-display"
						>Export your data</button
					>
					<p class="gag-fallback font-display">Already done.</p>
				</div>
				<p class="sub reveal mx-auto mt-8 max-w-xl">
					Other apps make you beg for your own data. Epicenter apps keep it as
					ordinary files on your computer from day one, so there is nothing to
					export because nothing was held.
				</p>
			</div>
		</section>

		<!-- Screen 3: The guarantee -->
		<section>
			<div class="mx-auto max-w-4xl px-6 py-28 text-center md:py-36">
				<h2 class="font-display reveal text-balance">
					Apps come and go. Your files shouldn't.
				</h2>
				<p class="sub reveal mx-auto mt-6 max-w-2xl">
					Epicenter apps save everything you make as ordinary files in a folder
					on your computer. Readable now, readable in twenty years, no account
					required.
				</p>
				<div class="vault-row mt-14 flex items-end justify-center gap-4 sm:gap-6">
					<div class="app-tile" style="--i: 0"><MessageCircleIcon /></div>
					<div class="app-tile" style="--i: 1"><ImageIcon /></div>
					<div class="folder-tile"><FolderIcon /></div>
					<div class="app-tile" style="--i: 2"><MusicIcon /></div>
					<div class="app-tile" style="--i: 3"><CalendarIcon /></div>
				</div>
				<p class="mono-caption mt-6">this folder is on your computer, not ours</p>
			</div>
		</section>

		<!-- Screen 4: The vision, staged as vision -->
		<section class="band">
			<div class="mx-auto max-w-4xl px-6 py-28 text-center md:py-36">
				<p class="eyebrow reveal">Where this is going</p>
				<h2 class="font-display reveal mt-4 text-balance">
					Everything you make, in one folder you keep.
				</h2>
				<p class="sub reveal mx-auto mt-6 max-w-2xl">
					That's what we're building: small apps for speaking, saving, and
					writing that all put their work into ordinary files on your computer.
					The first one, Whispering, is ready today.
				</p>
				<div
					class="reveal mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
				>
					<a class="cta cta-solid" data-download href={releasesUrl}>
						Start with Whispering
					</a>
					<a class="cta cta-outline" href={githubUrl}>Follow the build</a>
				</div>
			</div>
		</section>

		<!-- Screen 5: The letter -->
		<section>
			<div class="mx-auto max-w-2xl px-6 py-28 md:py-36">
				<p class="eyebrow reveal text-center">A note from the founder</p>
				<!--
					Owner-written copy goes here. Placeholder typesetting only; do not
					ship the final page without Braden's own five lines. See the spec's
					Open Question 1. The "if we disappeared tomorrow, your files
					wouldn't notice" beat belongs in this letter and nowhere else.
				-->
				<div class="letter reveal mt-10">
					<p>[Line one: why I built Whispering, in Braden's own words.]</p>
					<p>[Line two: the folder, lived in: what stays on this computer.]</p>
					<p>
						[Line three: the "if we disappeared tomorrow, your files wouldn't
						notice" beat lives here and nowhere else on the page.]
					</p>
					<p>[Line four: what comes next, stated as intent, not promise.]</p>
					<p>[Line five: an invitation to try it tonight.]</p>
					<p class="letter-sign">Braden</p>
				</div>
				<div class="reveal mt-12 flex flex-col items-center gap-4">
					<a class="cta cta-solid" data-download href={releasesUrl}>
						Download Whispering, free
					</a>
					<p class="fineprint">Free. macOS, Windows, and Linux.</p>
				</div>
			</div>
		</section>

		<footer class="band">
			<div
				class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 py-12 text-sm md:flex-row"
			>
				<p class="fineprint">
					© {year} Epicenter. Open source under the AGPL-3.0 license.
				</p>
				<div class="flex flex-wrap justify-center gap-x-7 gap-y-3">
					<a class="nav-link" href="/whispering#pricing">How is it free?</a>
					<a class="nav-link" href={githubUrl}>GitHub</a>
					<a class="nav-link" href={discordUrl}>Discord</a>
					<a class="nav-link" href="/blog">Blog</a>
				</div>
			</div>
		</footer>
	</main>
</BaseLayout>

<script is:inline define:vars={{ version: VERSION }}>
	document.documentElement.classList.add('js');

	// OS-detected download. The static href already points at the releases
	// page, so this only ever upgrades the link.
	const ua = navigator.userAgent.toLowerCase();
	const asset = (file) =>
		`https://github.com/EpicenterHQ/epicenter/releases/download/v${version}/${file}`;
	let downloadHref = null;
	if (ua.includes('mac')) {
		downloadHref = asset(`Whispering_${version}_aarch64.dmg`);
	} else if (ua.includes('win')) {
		downloadHref = asset(`Whispering_${version}_x64_en-US.msi`);
	}
	if (downloadHref) {
		for (const a of document.querySelectorAll('a[data-download]')) {
			a.href = downloadHref;
		}
	}

	// The export gag: one state change.
	const exportButton = document.getElementById('export-button');
	exportButton?.addEventListener('click', () => {
		if (exportButton.classList.contains('done')) return;
		exportButton.classList.add('done');
		exportButton.textContent = 'Already done.';
	});

	// Scroll reveals and the icons-fade visual share one observer.
	const observer = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (!entry.isIntersecting) continue;
				entry.target.classList.add('in');
				observer.unobserve(entry.target);
			}
		},
		{ threshold: 0.25 },
	);
	for (const el of document.querySelectorAll('.reveal, .vault-row')) {
		observer.observe(el);
	}

	// Typing simulation for the demo card. Without JS the full sentence is
	// already in the markup; with reduced motion we leave it alone.
	const typed = document.querySelector('[data-typed]');
	const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
	if (typed && !reduceMotion) {
		const sentence = typed.textContent.trim().replace(/\s+/g, ' ');
		let timer;
		const run = () => {
			clearTimeout(timer);
			typed.classList.add('typing');
			let i = 0;
			const tick = () => {
				typed.textContent = sentence.slice(0, i);
				if (i < sentence.length) {
					i += 1;
					timer = setTimeout(tick, 36 + Math.random() * 44);
				} else {
					typed.classList.remove('typing');
					timer = setTimeout(run, 7000);
				}
			};
			tick();
		};
		const demoObserver = new IntersectionObserver(
			(entries) => {
				if (entries.some((entry) => entry.isIntersecting)) {
					demoObserver.disconnect();
					run();
				}
			},
			{ threshold: 0.4 },
		);
		demoObserver.observe(typed);
		for (const a of document.querySelectorAll('a[href="#demo"]')) {
			a.addEventListener('click', run);
		}
	}
</script>

<style>
	/* Warm paper, ink, one ember accent. Fraunces carries the headlines. */
	.page {
		--paper: #faf5ec;
		--paper-deep: #f2ead9;
		--ink: #26221a;
		--ink-soft: #6f675a;
		--accent: #bc3f1d;
		--accent-deep: #9c3215;
		--line: #e2d8c2;
		background: var(--paper);
		color: var(--ink);
	}

	.font-display {
		font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
	}

	h1 {
		font-size: clamp(3rem, 9vw, 5.75rem);
		font-weight: 600;
		line-height: 1.02;
		letter-spacing: -0.02em;
	}

	h2 {
		font-size: clamp(2.1rem, 5.5vw, 3.5rem);
		font-weight: 550;
		line-height: 1.08;
		letter-spacing: -0.015em;
	}

	.sub {
		font-size: clamp(1.05rem, 2vw, 1.25rem);
		line-height: 1.65;
		color: var(--ink-soft);
	}

	.eyebrow {
		font-family: ui-monospace, 'SF Mono', Menlo, monospace;
		font-size: 0.8rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.fineprint {
		font-size: 0.85rem;
		color: var(--ink-soft);
	}

	.mono-caption {
		font-family: ui-monospace, 'SF Mono', Menlo, monospace;
		font-size: 0.85rem;
		color: var(--ink-soft);
	}

	.band {
		background: var(--paper-deep);
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}

	footer.band {
		border-bottom: none;
	}

	.nav-link {
		color: var(--ink-soft);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.nav-link:hover {
		color: var(--ink);
	}

	.quiet-link {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-color: var(--line);
		transition: text-decoration-color 150ms ease;
	}

	.quiet-link:hover {
		text-decoration-color: var(--accent);
	}

	.quiet-link + .quiet-link {
		margin-left: 1rem;
	}

	/* CTAs */
	.cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		padding: 0.9rem 1.9rem;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			transform 150ms ease,
			box-shadow 150ms ease,
			background-color 150ms ease,
			color 150ms ease;
	}

	.cta-solid {
		background: var(--accent);
		color: var(--paper);
		box-shadow: 0 2px 0 var(--accent-deep);
	}

	.cta-solid:hover {
		background: var(--accent-deep);
		transform: translateY(-1px);
		box-shadow: 0 3px 0 var(--accent-deep);
	}

	.cta-solid:active {
		transform: translateY(1px);
		box-shadow: none;
	}

	.cta-outline {
		border: 1.5px solid var(--ink);
		color: var(--ink);
	}

	.cta-outline:hover {
		background: var(--ink);
		color: var(--paper);
	}

	.cta-quiet {
		color: var(--ink);
		text-decoration: underline;
		text-underline-offset: 4px;
		text-decoration-color: var(--accent);
	}

	.cta-quiet:hover {
		color: var(--accent);
	}

	/* Hero load stagger: pure CSS, runs with or without JS */
	.hero-step {
		opacity: 0;
		animation: rise 0.7s ease-out forwards;
	}

	.hero-step:nth-child(1) {
		animation-delay: 0ms;
	}
	.hero-step:nth-child(2) {
		animation-delay: 120ms;
	}
	.hero-step:nth-child(3) {
		animation-delay: 240ms;
	}
	.hero-step:nth-child(4) {
		animation-delay: 320ms;
	}
	.hero-step:nth-child(5) {
		animation-delay: 440ms;
	}

	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(14px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Demo card */
	.demo-window {
		background: #fffdf8;
		border: 1px solid var(--line);
		border-radius: 14px;
		box-shadow:
			0 1px 2px rgb(38 34 26 / 6%),
			0 12px 32px rgb(38 34 26 / 8%);
		overflow: hidden;
	}

	.demo-titlebar {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 0.7rem 1rem;
		border-bottom: 1px solid var(--line);
	}

	.demo-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--line);
	}

	.demo-title {
		margin-left: 0.5rem;
		font-size: 0.8rem;
		color: var(--ink-soft);
	}

	.demo-field {
		padding: 0.55rem 1.1rem;
		border-bottom: 1px solid var(--line);
		font-size: 0.9rem;
	}

	.demo-field span {
		color: var(--ink-soft);
		margin-right: 0.35rem;
	}

	.demo-body {
		padding: 1.1rem;
		min-height: 6.5rem;
		font-size: 1rem;
		line-height: 1.6;
	}

	.demo-body.typing::after {
		content: '';
		display: inline-block;
		width: 2px;
		height: 1em;
		margin-left: 2px;
		vertical-align: -0.15em;
		background: var(--accent);
		animation: blink 1s steps(1) infinite;
	}

	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	.demo-hint {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.7rem 1.1rem;
		border-top: 1px solid var(--line);
		font-size: 0.8rem;
		color: var(--ink-soft);
	}

	.demo-hint kbd {
		font-family: ui-monospace, 'SF Mono', Menlo, monospace;
		font-size: 0.75rem;
		padding: 0.1rem 0.45rem;
		border: 1px solid var(--line);
		border-bottom-width: 2px;
		border-radius: 6px;
		background: var(--paper);
	}

	/* The export gag */
	.gag-btn {
		font-size: clamp(1.6rem, 4.5vw, 2.6rem);
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--ink);
		background: var(--paper);
		border: 2px solid var(--ink);
		border-radius: 18px;
		padding: 1.3rem 2.8rem;
		cursor: pointer;
		box-shadow: 0 6px 0 var(--ink);
		transition:
			transform 120ms ease,
			box-shadow 120ms ease,
			color 200ms ease,
			border-color 200ms ease;
	}

	.gag-btn:hover {
		transform: translateY(2px);
		box-shadow: 0 4px 0 var(--ink);
	}

	.gag-btn:active {
		transform: translateY(6px);
		box-shadow: 0 0 0 var(--ink);
	}

	.gag-btn.done {
		color: var(--accent);
		border-color: var(--accent);
		box-shadow: 0 6px 0 var(--accent);
		animation: stamp 350ms ease;
	}

	@keyframes stamp {
		0% {
			transform: scale(1.06) rotate(-1deg);
		}
		100% {
			transform: scale(1) rotate(0);
		}
	}

	/* Without JS the punchline prints right below the button. With JS the
	   click puts it on the button itself, so the static line stays hidden. */
	.gag-fallback {
		margin-top: 1rem;
		font-size: 1.2rem;
		font-style: italic;
		color: var(--accent);
	}

	:global(html.js) .gag-fallback {
		visibility: hidden;
	}

	/* Apps fade, the folder stays */
	.app-tile,
	.folder-tile {
		display: flex;
		align-items: center;
		justify-content: center;
		width: clamp(3.4rem, 9vw, 5rem);
		height: clamp(3.4rem, 9vw, 5rem);
		border-radius: 22%;
		border: 1px solid var(--line);
		background: #fffdf8;
	}

	.app-tile :global(svg),
	.folder-tile :global(svg) {
		width: 45%;
		height: 45%;
	}

	/* Static reading (and no-JS): the apps are already gone, the folder
	   remains. JS replays the decay when the row scrolls into view. */
	.app-tile {
		opacity: 0.3;
		filter: grayscale(1);
	}

	.folder-tile {
		width: clamp(4.2rem, 11vw, 6rem);
		height: clamp(4.2rem, 11vw, 6rem);
		background: var(--ink);
		border-color: var(--ink);
		color: var(--paper);
		box-shadow: 0 10px 24px rgb(38 34 26 / 18%);
	}

	:global(html.js) .vault-row .app-tile {
		opacity: 1;
		filter: none;
	}

	:global(html.js) .vault-row.in .app-tile {
		animation: fade-away 2.2s ease forwards;
		animation-delay: calc(0.5s + var(--i) * 0.35s);
	}

	@keyframes fade-away {
		to {
			opacity: 0.3;
			filter: grayscale(1);
		}
	}

	/* Scroll reveals: only when JS is present, never blocking static reads */
	:global(html.js) .reveal {
		opacity: 0;
		transform: translateY(16px);
		transition:
			opacity 0.7s ease,
			transform 0.7s ease;
	}

	:global(html.js) .reveal.in {
		opacity: 1;
		transform: none;
	}

	/* The letter */
	.letter {
		font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
		font-size: 1.15rem;
		line-height: 1.9;
		color: var(--ink);
	}

	.letter p + p {
		margin-top: 1.1rem;
	}

	.letter-sign {
		font-style: italic;
		font-size: 1.4rem;
		margin-top: 1.6rem;
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-step {
			animation: none;
			opacity: 1;
		}

		:global(html.js) .reveal {
			opacity: 1;
			transform: none;
			transition: none;
		}

		:global(html.js) .vault-row .app-tile {
			opacity: 0.3;
			filter: grayscale(1);
		}

		:global(html.js) .vault-row.in .app-tile {
			animation: none;
		}

		.gag-btn.done {
			animation: none;
		}
	}
</style>
