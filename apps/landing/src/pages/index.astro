---
import { Font } from 'astro:assets';
import {
	FileCog as FileCogIcon,
	FileText as FileTextIcon,
	Folder as FolderIcon,
} from '@lucide/astro';
import AppSwitcher from '../components/ecosystem/AppSwitcher.astro';
import AppTile from '../components/ecosystem/AppTile.astro';
import { APPS } from '../lib/apps';
import BaseLayout from '../layouts/BaseLayout.astro';

const year = new Date().getFullYear();
const githubUrl = 'https://github.com/EpicenterHQ/epicenter';
const discordUrl = 'https://go.epicenter.so/discord';
---

<BaseLayout
	title="Epicenter: purpose-built apps, one folder you own"
	description="Epicenter is a growing family of small, purpose-built apps that save everything you make as ordinary files in one folder on your computer. Start with Whispering, our free speech-to-text app for macOS, Windows, and Linux."
>
	<Fragment slot="head">
		<Font cssVariable="--font-fraunces" preload />
	</Fragment>

	<main class="page">
		<AppSwitcher />

		<!-- Umbrella hero: the direction, not one app -->
		<header
			class="mx-auto flex min-h-[78svh] max-w-5xl flex-col items-center justify-center px-6 pb-20 pt-12 text-center"
		>
			<p class="eyebrow hero-step" style="--step: 0">A home for what you make</p>
			<h1 class="font-display hero-step text-balance" style="--step: 1">
				Purpose-built apps.<br />One folder you own.
			</h1>
			<p class="sub hero-step mx-auto mt-7 max-w-2xl" style="--step: 2">
				Epicenter is a growing family of small apps for speaking, writing, and
				learning. Each one is built for a single job, and each one saves your
				work as ordinary files in one folder on your computer.
			</p>
			<div
				class="hero-step mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
				style="--step: 3"
			>
				<a class="cta cta-solid" href="#apps">Browse the apps</a>
				<a class="cta cta-quiet" href="/whispering">Start with Whispering</a>
			</div>
			<p class="fineprint hero-step mt-5" style="--step: 4">
				Whispering, our speech-to-text app, is ready today. Free for macOS,
				Windows, and Linux.
			</p>
		</header>

		<!-- The ecosystem browser: the visual twin of the switcher -->
		<section id="apps">
			<div class="mx-auto max-w-5xl px-6 py-24 md:py-32">
				<div class="text-center">
					<p class="eyebrow reveal">The apps</p>
					<h2 class="font-display reveal mt-4 text-balance">
						One family, one folder.
					</h2>
					<p class="sub reveal mx-auto mt-5 max-w-2xl">
						Each app stands on its own. Together they write to the same folder,
						so everything you capture lives in one place that belongs to you.
					</p>
				</div>
				<div class="grid reveal mt-12 gap-5 sm:grid-cols-2 lg:grid-cols-3">
					{APPS.map((app) => <AppTile app={app} />)}
				</div>
			</div>
		</section>

		<!-- The shared guarantee, delivered as the export gag -->
		<section class="band">
			<div class="mx-auto max-w-3xl px-6 py-28 text-center md:py-36">
				<h2 class="font-display reveal text-balance">
					Apps come and go. Your files shouldn't.
				</h2>
				<div class="reveal mt-10">
					<button type="button" class="gag-btn font-display">
						Export your data
					</button>
					<p class="gag-fallback font-display">Already done.</p>
				</div>
				<p class="sub reveal mx-auto mt-8 max-w-xl">
					Other apps make you beg for your own data. Epicenter apps keep it as
					ordinary files in your folder from day one, so there is nothing to
					export because nothing was held.
				</p>
			</div>
		</section>

		<!-- The folder: everything lands in one place you keep -->
		<section id="folder">
			<div class="mx-auto max-w-2xl px-6 py-28 text-center md:py-36">
				<p class="eyebrow reveal">Where it all lands</p>
				<h2 class="font-display reveal mt-4 text-balance">
					Everything in one folder you keep.
				</h2>
				<p class="sub reveal mx-auto mt-6 max-w-xl">
					Readable now, readable in twenty years, no account required. Every app
					you add writes alongside the last, in plain files you can open, search,
					and back up yourself.
				</p>
				<div class="tree-wrap reveal mt-12 w-full text-left">
					<div class="demo-window">
						<div class="demo-titlebar">
							<span class="demo-dot"></span><span class="demo-dot"></span
							><span class="demo-dot"></span>
							<span class="demo-title">my-brain</span>
						</div>
						<div class="ns-tree">
							<div class="ns-row"><FolderIcon /> my-brain/</div>
							<div class="ns-row i1" data-step="1"><FolderIcon /> journal/</div>
							<div class="ns-row i1" data-step="1"><FolderIcon /> ideas/</div>
							<div class="ns-row i1" data-step="2">
								<FolderIcon /> whispering/
							</div>
							<div
								class="ns-row i2 ns-file ns-managed"
								data-step="3"
								title="Epicenter setup file"
							>
								<FileCogIcon /> epicenter.config.ts
							</div>
							<div class="ns-row i2 ns-file" data-step="4">
								<FileTextIcon /> standup.md
							</div>
							<div class="ns-row i1" data-step="5">
								<FolderIcon /> honeycrisp/
							</div>
							<div
								class="ns-row i2 ns-file ns-managed"
								data-step="6"
								title="Epicenter setup file"
							>
								<FileCogIcon /> epicenter.config.ts
							</div>
							<div class="ns-row i2 ns-file" data-step="7">
								<FileTextIcon /> meeting-notes.md
							</div>
							<div class="ns-row i1" data-step="8"><FolderIcon /> vocab/</div>
							<div
								class="ns-row i2 ns-file ns-managed"
								data-step="9"
								title="Epicenter setup file"
							>
								<FileCogIcon /> epicenter.config.ts
							</div>
							<div class="ns-row i2 ns-file" data-step="10">
								<FileTextIcon /> spanish.md
							</div>
						</div>
					</div>
					<p class="ns-caption mono-caption mt-4 text-center">
						Your folder. Every app writes here.
					</p>
				</div>
			</div>
		</section>

		<!-- The letter -->
		<section class="band">
			<div class="mx-auto max-w-2xl px-6 py-28 md:py-36">
				<p class="eyebrow reveal text-center">A note from the founder</p>
				<!--
					DRAFT in Braden's intended voice. Replace with your own words before
					launch; keep the "if we disappeared tomorrow" beat here and nowhere
					else. Plain and specific on purpose: the founder voice is the antidote
					to a page that reads as generated.
				-->
				<div class="letter reveal mt-10">
					<p>
						I kept hitting the same wall: every app I loved held my work hostage.
						Notes, transcripts, drafts, all locked in a database I couldn't see,
						exportable only if the company felt like letting me.
					</p>
					<p>
						So I started building the opposite. Small apps, each built for one
						job, each writing everything it makes to a folder on your computer as
						plain files. Open them anywhere, search them, back them up, or leave.
					</p>
					<p>
						Here's the part that matters: if Epicenter disappeared tomorrow, your
						files wouldn't notice. Nothing to export, nothing to rescue. They are
						already yours, in a format that outlives any app, including mine.
					</p>
					<p>
						Whispering is ready today. More are coming, one honest release at a
						time. I would rather earn the family slowly than promise it before
						it's real.
					</p>
					<p class="letter-sign">Braden</p>
				</div>
				<div class="reveal mt-12 flex flex-col items-center gap-4">
					<a class="cta cta-solid" href="/whispering">Start with Whispering</a>
					<p class="fineprint">Free. macOS, Windows, and Linux.</p>
				</div>
			</div>
		</section>

		<footer class="band footer-band">
			<div
				class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 py-12 text-sm md:flex-row"
			>
				<p class="fineprint">
					© {year} Epicenter. Open source under the AGPL-3.0 license.
				</p>
				<div class="flex flex-wrap justify-center gap-x-7 gap-y-3">
					<a class="nav-link" href="/whispering#pricing">How is it free?</a>
					<a class="nav-link" href={githubUrl}>GitHub</a>
					<a class="nav-link" href={discordUrl}>Discord</a>
					<a class="nav-link" href="/blog">Blog</a>
				</div>
			</div>
		</footer>
	</main>
</BaseLayout>

<script is:inline>
	// Runs on first load and after every view-transition navigation.
	document.addEventListener('astro:page-load', () => {
	const motionOK = matchMedia('(prefers-reduced-motion: no-preference)').matches;

	// The export gag: one state change.
	for (const btn of document.querySelectorAll('.gag-btn')) {
		btn.addEventListener('click', () => {
			if (btn.classList.contains('done')) return;
			btn.classList.add('done');
			btn.textContent = 'Already done.';
		});
	}

	// CSS hides animated elements; JS reveals them. Run fn once, when el is seen.
	const inView = (el, fn, threshold = 0.15) => {
		if (!el) return;
		const io = new IntersectionObserver(
			(entries) => {
				if (entries.some((e) => e.isIntersecting)) {
					io.disconnect();
					fn();
				}
			},
			{ threshold },
		);
		io.observe(el);
	};

	// Animate from a hidden keyframe to the element's natural state. The forwards
	// fill keeps the end state and outranks the CSS hidden rule.
	const reveal = (el, from, ms = 600) =>
		el.animate([from, { opacity: 1, filter: 'none', transform: 'none' }], {
			duration: ms,
			easing: 'cubic-bezier(0.2, 0.6, 0.2, 1)',
			fill: 'forwards',
		});

	// Scroll reveals.
	for (const el of document.querySelectorAll('.reveal'))
		inView(el, () =>
			motionOK ? reveal(el, { opacity: 0, transform: 'translateY(16px)' }) : null,
		);

	// The folder fills in one branch at a time when scrolled into view.
	const tree = document.querySelector('.ns-tree');
	if (tree && motionOK) {
		const rows = [...tree.querySelectorAll('[data-step]')];
		const lastStep = Math.max(...rows.map((row) => +row.dataset.step));
		inView(
			tree,
			() => {
				let step = 0;
				const advance = () => {
					step += 1;
					for (const r of rows)
						if (+r.dataset.step === step)
							reveal(r, { opacity: 0, transform: 'translateX(-8px)' });
					if (step < lastStep) setTimeout(advance, 260);
				};
				advance();
			},
			0.2,
		);
	}
	});
</script>
