---
import { Font } from 'astro:assets';
import { VERSION } from '@epicenter/constants/versions';
import {
	FileText as FileTextIcon,
	Folder as FolderIcon,
	Mic as MicIcon,
	NotebookPen as NotebookPenIcon,
	StickyNote as StickyNoteIcon,
} from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const year = new Date().getFullYear();
const releasesUrl = 'https://github.com/EpicenterHQ/epicenter/releases/latest';
const githubUrl = 'https://github.com/EpicenterHQ/epicenter';
const discordUrl = 'https://go.epicenter.so/discord';
---

<BaseLayout
	title="Epicenter: say it once, keep it forever"
	description="Whispering is a free speech-to-text app that types wherever your cursor is and saves every capture as a plain Markdown file in a folder you own. macOS, Windows, and Linux."
>
	<Fragment slot="head">
		<Font cssVariable="--font-fraunces" preload />
		<script is:inline>
			document.documentElement.classList.add('js');
		</script>
	</Fragment>

	<main class="page">
		<!-- Nav: one quiet door for developers, nothing more -->
		<nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
			<a href="/" class="font-display text-xl font-semibold tracking-tight"
				>Epicenter</a
			>
			<div class="flex items-center gap-6 text-sm">
				<a class="nav-link" href="/whispering">Whispering</a>
				<a class="nav-link" href="/blog">Blog</a>
				<a class="nav-link" href={githubUrl}>GitHub</a>
				<a class="nav-link hidden sm:inline" href={discordUrl}>Discord</a>
			</div>
		</nav>

		<!-- Hero: speak, and the words become a file you own -->
		<header
			class="mx-auto flex min-h-[90svh] max-w-5xl flex-col items-center justify-center px-6 pb-20 pt-8 text-center"
		>
			<p class="eyebrow hero-step" style="--step: 0">Speak it. Keep it.</p>
			<h1 class="font-display hero-step text-balance" style="--step: 1">
				Say it once. Keep it forever.
			</h1>
			<p class="sub hero-step mx-auto mt-7 max-w-2xl" style="--step: 2">
				Whispering turns your voice into text wherever your cursor is, and saves
				every capture as a plain Markdown file in a folder you own. Free, and
				ready tonight.
			</p>
			<div
				class="hero-step mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
				style="--step: 3"
			>
				<a class="cta cta-solid" data-download href={releasesUrl}
					>Download Whispering, free</a
				>
				<a class="cta cta-quiet" href="#anywhere">See how it works</a>
			</div>
			<p class="fineprint hero-step mt-5" style="--step: 4">
				Free and open source. macOS, Windows, and Linux.
			</p>

			<!-- The capture demo: speak on the left, a file lands on the right -->
			<figure class="cap hero-step mt-14 w-full max-w-3xl" style="--step: 5">
				<div class="cap-panel cap-mic">
					<div class="cap-rec"><span class="cap-dot"></span> Listening</div>
					<p class="cap-text" data-typed>
						Just left the office, traffic is slow on the bridge. I should be
						there by seven.
					</p>
				</div>
				<div class="cap-arrow" aria-hidden="true">&#8594;</div>
				<div class="cap-panel demo-window">
					<div class="demo-titlebar">
						<span class="demo-dot"></span><span class="demo-dot"></span
						><span class="demo-dot"></span>
						<span class="demo-title">my-brain</span>
					</div>
					<div class="ns-tree bare">
						<div class="ns-row"><FolderIcon /> apps/</div>
						<div class="ns-row i1"><FolderIcon /> whispering/</div>
						<div class="ns-row i2 ns-file cap-file">
							<FileTextIcon />
							standup.md
						</div>
					</div>
				</div>
			</figure>
			<p class="cap-caption hero-step mono-caption mt-6" style="--step: 6">
				Hold your shortcut and speak.
			</p>
		</header>

		<!-- It works in every app: words land at your cursor -->
		<section id="anywhere">
			<div class="mx-auto max-w-4xl px-6 py-28 text-center md:py-36">
				<p class="eyebrow reveal">Works where you already work</p>
				<h2 class="font-display reveal mt-4 text-balance">
					It types into whatever app you're in.
				</h2>
				<p class="sub reveal mx-auto mt-6 max-w-2xl">
					No special window, no copy-paste. Hold your shortcut, talk, and the
					words land at your cursor: email, docs, chat, your editor.
				</p>
				<figure class="reveal mx-auto mt-12 w-full max-w-xl text-left">
					<div class="demo-window">
						<div class="demo-titlebar">
							<span class="demo-dot"></span><span class="demo-dot"></span
							><span class="demo-dot"></span>
							<span class="demo-title">New Message</span>
						</div>
						<div class="demo-field"><span>To:</span> Sam</div>
						<div class="demo-field"><span>Subject:</span> Running late</div>
						<p class="demo-body" data-typed>
							Just left the office, traffic is slow on the bridge. I should be
							there by seven. Want me to grab dinner on the way?
						</p>
						<div class="demo-hint">
							<span class="demo-mic"></span>
							<span
								>Hold your shortcut and talk. Release, and the words type
								themselves.</span
							>
						</div>
					</div>
					<figcaption class="fineprint mt-3 text-center">
						Simulated. It works the same in any text field.
					</figcaption>
				</figure>
			</div>
		</section>

		<!-- The gag: nothing to export, it was always yours -->
		<section class="band">
			<div class="mx-auto max-w-3xl px-6 py-28 text-center md:py-36">
				<div class="reveal">
					<button type="button" class="gag-btn font-display">
						Export your data
					</button>
					<p class="gag-fallback font-display">Already done.</p>
				</div>
				<p class="sub reveal mx-auto mt-8 max-w-xl">
					Other apps make you beg for your own data. Epicenter apps keep it as
					ordinary files in your folder from day one, so there is nothing to
					export because nothing was held.
				</p>
			</div>
		</section>

		<!-- Zoom out: one folder, every app -->
		<section id="how">
			<div class="mx-auto max-w-2xl px-6 py-28 text-center md:py-36">
				<p class="eyebrow reveal">Zoom out</p>
				<h2 class="font-display reveal mt-4 text-balance">
					One folder, every app.
				</h2>
				<p class="sub reveal mx-auto mt-6 max-w-xl">
					Drop an epicenter.config.ts into any folder and Epicenter manages it.
					Whispering writes here today. Fuji, Honeycrisp, and every app you add
					write alongside it as Markdown you own.
				</p>
				<div class="ns reveal mt-12 w-full text-left">
					<div class="ns-apps">
						<span class="ns-chip" data-step="3"><MicIcon /> Whispering</span>
						<span class="ns-chip" data-step="4"><NotebookPenIcon /> Fuji</span>
						<span class="ns-chip" data-step="5"
							><StickyNoteIcon />
							Honeycrisp</span
						>
					</div>
					<div class="demo-window">
						<div class="demo-titlebar">
							<span class="demo-dot"></span><span class="demo-dot"></span
							><span class="demo-dot"></span>
							<span class="demo-title">my-brain</span>
						</div>
						<div class="ns-tree bare">
							<div class="ns-row"><FolderIcon /> my-brain/</div>
							<div class="ns-row i1"><FolderIcon /> journal/</div>
							<div class="ns-row i1"><FolderIcon /> ideas/</div>
							<div class="ns-row i1 ns-reserved" data-step="1">
								<FolderIcon />
								apps/<span class="ns-tag" data-step="2">Epicenter-managed</span>
							</div>
							<div class="ns-row i2 ns-config" data-step="2">
								<FileTextIcon />
								epicenter.config.ts
							</div>
							<div class="ns-row i2" data-step="3">
								<FolderIcon />
								whispering/
							</div>
							<div class="ns-row i3 ns-file" data-step="3">
								<FileTextIcon />
								standup.md
							</div>
							<div class="ns-row i2" data-step="4"><FolderIcon /> fuji/</div>
							<div class="ns-row i3 ns-file" data-step="4">
								<FileTextIcon />
								trip-japan.md
							</div>
							<div class="ns-row i2" data-step="5">
								<FolderIcon />
								honeycrisp/
							</div>
							<div class="ns-row i3 ns-file" data-step="5">
								<FileTextIcon />
								meeting-notes.md
							</div>
						</div>
					</div>
					<p class="ns-caption mono-caption mt-4 text-center">
						Your own folder of Markdown.
					</p>
				</div>
			</div>
		</section>

		<!-- The guarantee -->
		<section class="band">
			<div class="mx-auto max-w-3xl px-6 py-28 text-center md:py-36">
				<h2 class="font-display reveal text-balance">
					Apps come and go. Your files shouldn't.
				</h2>
				<p class="sub reveal mx-auto mt-6 max-w-2xl">
					Readable now, readable in twenty years, no account required.
				</p>
			</div>
		</section>

		<!-- The letter -->
		<section>
			<div class="mx-auto max-w-2xl px-6 py-28 md:py-36">
				<p class="eyebrow reveal text-center">A note from the founder</p>
				<!--
					Owner-written copy goes here. Placeholder typesetting only; do not
					ship the final page without Braden's own five lines. The "if we
					disappeared tomorrow, your files wouldn't notice" beat belongs in this
					letter and nowhere else.
				-->
				<div class="letter reveal mt-10">
					<p>[Line one: why I built Whispering, in Braden's own words.]</p>
					<p>[Line two: the folder, lived in: what stays on this computer.]</p>
					<p>
						[Line three: the "if we disappeared tomorrow, your files wouldn't
						notice" beat lives here and nowhere else on the page.]
					</p>
					<p>[Line four: what comes next, stated as intent, not promise.]</p>
					<p>[Line five: an invitation to try it tonight.]</p>
					<p class="letter-sign">Braden</p>
				</div>
				<div class="reveal mt-12 flex flex-col items-center gap-4">
					<a class="cta cta-solid" data-download href={releasesUrl}
						>Download Whispering, free</a
					>
					<p class="fineprint">Free. macOS, Windows, and Linux.</p>
				</div>
			</div>
		</section>

		<footer class="band">
			<div
				class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 py-12 text-sm md:flex-row"
			>
				<p class="fineprint">
					© {year} Epicenter. Open source under the AGPL-3.0 license.
				</p>
				<div class="flex flex-wrap justify-center gap-x-7 gap-y-3">
					<a class="nav-link" href="/whispering#pricing">How is it free?</a>
					<a class="nav-link" href={githubUrl}>GitHub</a>
					<a class="nav-link" href={discordUrl}>Discord</a>
					<a class="nav-link" href="/blog">Blog</a>
				</div>
			</div>
		</footer>
	</main>
</BaseLayout>

<script is:inline define:vars={{ version: VERSION }}>
	const motionOK = matchMedia(
		'(prefers-reduced-motion: no-preference)',
	).matches;

	// OS-detected download. The static href already points at the releases
	// page, so this only ever upgrades the link.
	const ua = navigator.userAgent.toLowerCase();
	const asset = (file) =>
		`https://github.com/EpicenterHQ/epicenter/releases/download/v${version}/${file}`;
	let downloadHref = null;
	if (ua.includes('mac'))
		downloadHref = asset(`Whispering_${version}_aarch64.dmg`);
	else if (ua.includes('win'))
		downloadHref = asset(`Whispering_${version}_x64_en-US.msi`);
	if (downloadHref) {
		for (const a of document.querySelectorAll('a[data-download]'))
			a.href = downloadHref;
	}

	// The export gag: one state change.
	for (const btn of document.querySelectorAll('.gag-btn')) {
		btn.addEventListener('click', () => {
			if (btn.classList.contains('done')) return;
			btn.classList.add('done');
			btn.textContent = 'Already done.';
		});
	}

	// CSS hides animated elements; JS reveals them. Run fn once, when el is seen.
	const inView = (el, fn, threshold = 0.25) => {
		if (!el) return;
		const io = new IntersectionObserver(
			(entries) => {
				if (entries.some((e) => e.isIntersecting)) {
					io.disconnect();
					fn();
				}
			},
			{ threshold },
		);
		io.observe(el);
	};

	// Animate from a hidden keyframe to the element's natural state. The forwards
	// fill keeps the end state and outranks the CSS hidden rule, so there is no
	// revealed-state rule to keep in sync.
	const reveal = (el, from, ms = 600) =>
		el.animate([from, { opacity: 1, filter: 'none', transform: 'none' }], {
			duration: ms,
			easing: 'cubic-bezier(0.2, 0.6, 0.2, 1)',
			fill: 'forwards',
		});

	// Type a sentence into el, character by character.
	const type = (el, done) => {
		const text =
			el.getAttribute('data-text') ||
			el.textContent.trim().replace(/\s+/g, ' ');
		el.setAttribute('data-text', text);
		if (!motionOK) {
			el.textContent = text;
			done && done();
			return;
		}
		el.classList.add('typing');
		el.textContent = '';
		let i = 0;
		const tick = () => {
			el.textContent = text.slice(0, (i += 1));
			if (i < text.length) setTimeout(tick, 36 + Math.random() * 44);
			else {
				el.classList.remove('typing');
				done && done();
			}
		};
		tick();
	};

	// Scroll reveals.
	for (const el of document.querySelectorAll('.reveal'))
		inView(
			el,
			() =>
				motionOK && reveal(el, { opacity: 0, transform: 'translateY(16px)' }),
			0.15,
		);

	// Hero: speak, and the words become a file you own.
	const capText = document.querySelector('.cap-text[data-typed]');
	if (capText) {
		const file = document.querySelector('.cap-file');
		const rec = document.querySelector('.cap-rec');
		const caption = document.querySelector('.cap-caption');
		if (motionOK && rec) rec.classList.add('on');
		type(capText, () => {
			rec && rec.classList.remove('on');
			if (caption)
				caption.textContent = 'Release. The words become a file you own.';
			if (file && motionOK)
				reveal(file, { opacity: 0, transform: 'translateX(-16px)' });
		});
	}

	// Anywhere section: the email types itself when scrolled into view.
	const email = document.querySelector('.demo-body[data-typed]');
	if (email) inView(email, () => type(email), 0.4);

	// Zoom out: apps/ folder, then config, then each app, one frame at a time.
	const ns = document.querySelector('.ns');
	if (ns && motionOK) {
		const rows = [...ns.querySelectorAll('.ns-tree [data-step]')];
		const chips = [...ns.querySelectorAll('.ns-chip')];
		const caption = ns.querySelector('.ns-caption');
		const captions = {
			1: 'Pick any folder in your vault, named whatever you like.',
			2: 'Drop in epicenter.config.ts. Now the folder is Epicenter-managed.',
			3: 'Whispering writes its transcripts here.',
			4: 'Fuji writes its entries here.',
			5: 'Honeycrisp writes its notes here. Every app you add does the same.',
		};
		inView(
			ns,
			() => {
				let step = 0;
				const advance = () => {
					step += 1;
					for (const r of rows)
						if (+r.dataset.step === step)
							reveal(r, { opacity: 0, transform: 'translateY(-4px)' });
					for (const c of chips)
						if (+c.dataset.step === step)
							reveal(c, { opacity: 0.4, filter: 'grayscale(1)' });
					if (caption && captions[step]) caption.textContent = captions[step];
					if (step < 5) setTimeout(advance, 1100);
				};
				advance();
			},
			0.2,
		);
	}
</script>

<style>
	/* Warm paper, ink, one ember accent. Fraunces carries the headlines. */
	.page {
		--paper: #faf5ec;
		--paper-deep: #f2ead9;
		--ink: #26221a;
		--ink-soft: #6f675a;
		--accent: #bc3f1d;
		--accent-deep: #9c3215;
		--line: #e2d8c2;
		background: var(--paper);
		color: var(--ink);
	}

	.font-display {
		font-family: var(--font-fraunces, Georgia, serif);
	}

	h1 {
		font-size: clamp(3rem, 9vw, 5.75rem);
		font-weight: 600;
		line-height: 1.02;
		letter-spacing: -0.02em;
	}

	h2 {
		font-size: clamp(2.1rem, 5.5vw, 3.5rem);
		font-weight: 550;
		line-height: 1.08;
		letter-spacing: -0.015em;
	}

	.sub {
		font-size: clamp(1.05rem, 2vw, 1.25rem);
		line-height: 1.65;
		color: var(--ink-soft);
	}

	.eyebrow {
		font-family: ui-monospace, "SF Mono", Menlo, monospace;
		font-size: 0.8rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.fineprint {
		font-size: 0.85rem;
		color: var(--ink-soft);
	}

	.mono-caption {
		font-family: ui-monospace, "SF Mono", Menlo, monospace;
		font-size: 0.85rem;
		color: var(--ink-soft);
	}

	.band {
		background: var(--paper-deep);
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}

	footer.band {
		border-bottom: none;
	}

	.nav-link {
		color: var(--ink-soft);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.nav-link:hover {
		color: var(--ink);
	}

	/* CTAs */
	.cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		padding: 0.9rem 1.9rem;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			transform 150ms ease,
			box-shadow 150ms ease,
			background-color 150ms ease,
			color 150ms ease;
	}

	.cta-solid {
		background: var(--accent);
		color: var(--paper);
		box-shadow: 0 2px 0 var(--accent-deep);
	}

	.cta-solid:hover {
		background: var(--accent-deep);
		transform: translateY(-1px);
		box-shadow: 0 3px 0 var(--accent-deep);
	}

	.cta-solid:active {
		transform: translateY(1px);
		box-shadow: none;
	}

	.cta-quiet {
		color: var(--ink);
		text-decoration: underline;
		text-underline-offset: 4px;
		text-decoration-color: var(--accent);
	}

	.cta-quiet:hover {
		color: var(--accent);
	}

	/* Hero load stagger: pure CSS, runs with or without JS */
	.hero-step {
		opacity: 0;
		animation: rise 0.7s ease-out forwards;
		animation-delay: calc(var(--step) * 110ms);
	}

	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(14px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Demo / Finder window */
	.demo-window {
		background: #fffdf8;
		border: 1px solid var(--line);
		border-radius: 14px;
		box-shadow:
			0 1px 2px rgb(38 34 26 / 6%),
			0 12px 32px rgb(38 34 26 / 8%);
		overflow: hidden;
	}

	.demo-titlebar {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 0.7rem 1rem;
		border-bottom: 1px solid var(--line);
	}

	.demo-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--line);
	}

	.demo-title {
		margin-left: 0.5rem;
		font-size: 0.8rem;
		color: var(--ink-soft);
	}

	.demo-field {
		padding: 0.55rem 1.1rem;
		border-bottom: 1px solid var(--line);
		font-size: 0.9rem;
	}

	.demo-field span {
		color: var(--ink-soft);
		margin-right: 0.35rem;
	}

	.demo-body {
		padding: 1.1rem;
		min-height: 6.5rem;
		font-size: 1rem;
		line-height: 1.6;
	}

	.demo-body.typing::after,
	.cap-text.typing::after {
		content: "";
		display: inline-block;
		width: 2px;
		height: 1em;
		margin-left: 2px;
		vertical-align: -0.15em;
		background: var(--accent);
		animation: blink 1s steps(1) infinite;
	}

	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	.demo-hint {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.7rem 1.1rem;
		border-top: 1px solid var(--line);
		font-size: 0.8rem;
		color: var(--ink-soft);
	}

	.demo-mic {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--accent);
		animation: pulse 1.6s ease-in-out infinite;
	}

	@keyframes pulse {
		50% {
			opacity: 0.35;
		}
	}

	/* The export gag */
	.gag-btn {
		font-size: clamp(1.6rem, 4.5vw, 2.6rem);
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--ink);
		background: var(--paper);
		border: 2px solid var(--ink);
		border-radius: 18px;
		padding: 1.3rem 2.8rem;
		cursor: pointer;
		box-shadow: 0 6px 0 var(--ink);
		transition:
			transform 120ms ease,
			box-shadow 120ms ease,
			color 200ms ease,
			border-color 200ms ease;
	}

	.gag-btn:hover {
		transform: translateY(2px);
		box-shadow: 0 4px 0 var(--ink);
	}

	.gag-btn:active {
		transform: translateY(6px);
		box-shadow: 0 0 0 var(--ink);
	}

	.gag-btn.done {
		color: var(--accent);
		border-color: var(--accent);
		box-shadow: 0 6px 0 var(--accent);
		animation: stamp 350ms ease;
	}

	@keyframes stamp {
		0% {
