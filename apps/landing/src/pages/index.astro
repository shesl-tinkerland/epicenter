---
import { Font } from 'astro:assets';
import AppFooter from '../components/ecosystem/AppFooter.astro';
import AppSwitcher from '../components/ecosystem/AppSwitcher.astro';
import AppsFolder from '../components/ecosystem/AppsFolder.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Epicenter: purpose-built apps, one folder you own"
	description="Epicenter is a growing family of small, purpose-built apps that save everything you make as ordinary files in one folder on your computer. Start with Whispering, our free speech-to-text app for macOS, Windows, and Linux."
>
	<Fragment slot="head">
		<Font cssVariable="--font-fraunces" preload />
	</Fragment>

	<main class="page">
		<AppSwitcher />

		<!-- Umbrella hero: the direction, not one app -->
		<header
			class="mx-auto flex min-h-[78svh] max-w-5xl flex-col items-center justify-center px-6 pb-20 pt-12 text-center"
		>
			<p class="eyebrow hero-step" style="--step: 0">A home for what you make</p>
			<h1 class="font-display hero-step text-balance" style="--step: 1">
				Purpose-built apps.<br />One folder you own.
			</h1>
			<p class="sub hero-step mx-auto mt-7 max-w-2xl" style="--step: 2">
				Epicenter is a growing family of small apps for speaking, writing, and
				learning. Each one is built for a single job, and each one saves your
				work as ordinary files in one folder on your computer.
			</p>
			<div
				class="hero-step mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
				style="--step: 3"
			>
				<a class="cta cta-solid" href="#apps">Browse the apps</a>
				<a class="cta cta-quiet" href="/whispering">Start with Whispering</a>
			</div>
			<p class="fineprint hero-step mt-5" style="--step: 4">
				Whispering, our speech-to-text app, is ready today. Free for macOS,
				Windows, and Linux.
			</p>
		</header>

		<!-- The apps and the one folder they write to, fused into one beat -->
		<AppsFolder />

		<!-- The shared guarantee, delivered as the export gag -->
		<section class="band">
			<div class="mx-auto max-w-3xl px-6 py-28 text-center md:py-36">
				<h2 class="font-display reveal text-balance">
					Apps come and go. Your files shouldn't.
				</h2>
				<div class="reveal mt-10">
					<button type="button" class="gag-btn font-display">
						Export your data
					</button>
					<p class="gag-fallback font-display">Already done.</p>
				</div>
				<p class="sub reveal mx-auto mt-8 max-w-xl">
					Other apps make you beg for your own data. Epicenter apps keep it as
					ordinary files in your folder from day one, so there is nothing to
					export because nothing was held.
				</p>
			</div>
		</section>

		<!-- The letter -->
		<section class="band">
			<div class="mx-auto max-w-2xl px-6 py-28 md:py-36">
				<p class="eyebrow reveal text-center">A note from the founder</p>
				<div class="letter reveal mt-10">
					<p>
						I keep losing trust in apps when the only copy of my work lives
						inside them.
					</p>
					<p>
						It happens slowly. A transcript is in one place, notes are in
						another, drafts are somewhere else. Each app might be useful, but the
						trail only makes sense if I keep using that app.
					</p>
					<p>
						I want the trail to be mine. That is why Epicenter apps write plain
						files into a folder on your computer. You can open the files directly,
						search them, back them up, put them in Git, or move on.
					</p>
					<p>
						The test I keep coming back to is simple: if I stopped working on
						Epicenter tomorrow, would your work still be okay? It should be.
						Whispering is ready today. Honeycrisp and Vocab are still being built
						in public; I want the page to say that plainly until they earn their
						place.
					</p>
					<p class="letter-sign">Braden</p>
				</div>
				<div class="reveal mt-12 flex flex-col items-center gap-4">
					<a class="cta cta-solid" href="/whispering">Start with Whispering</a>
					<p class="fineprint">Free. macOS, Windows, and Linux.</p>
				</div>
			</div>
		</section>

		<AppFooter showPricing />
	</main>
</BaseLayout>

<script>
	// Module script: runs once and registers a single astro:page-load listener
	// that re-binds against the freshly swapped DOM on each navigation. (An
	// is:inline script re-executes per navigation and leaks a listener each time.)
	// The folder's staged fill lives in AppsFolder.astro; this handles the export
	// gag and the generic scroll reveals.
	const init = () => {
		const motionOK = matchMedia(
			'(prefers-reduced-motion: no-preference)',
		).matches;

		// The export gag: one state change.
		for (const btn of Array.from(
			document.querySelectorAll<HTMLButtonElement>('.gag-btn'),
		)) {
			if (btn.dataset.gagBound === 'true') continue;
			btn.dataset.gagBound = 'true';
			btn.addEventListener('click', () => {
				if (btn.classList.contains('done')) return;
				btn.classList.add('done');
				btn.textContent = 'Already done.';
			});
		}

		// CSS hides animated elements; JS reveals them. Run fn once, when seen.
		const inView = (
			el: Element | null,
			fn: () => void,
			threshold = 0.15,
		) => {
			if (!el) return;
			const io = new IntersectionObserver(
				(entries) => {
					if (entries.some((e) => e.isIntersecting)) {
						io.disconnect();
						fn();
					}
				},
				{ threshold },
			);
			io.observe(el);
		};

		// Animate from a hidden keyframe to the element's natural state. The
		// forwards fill keeps the end state and outranks the CSS hidden rule.
		const reveal = (el: Element, from: Keyframe, ms = 600) =>
			el.animate([from, { opacity: 1, filter: 'none', transform: 'none' }], {
				duration: ms,
				easing: 'cubic-bezier(0.2, 0.6, 0.2, 1)',
				fill: 'forwards',
			});

		for (const el of Array.from(document.querySelectorAll<HTMLElement>('.reveal'))) {
			if (el.dataset.revealBound === 'true') continue;
			el.dataset.revealBound = 'true';
			inView(el, () =>
				motionOK
					? reveal(el, { opacity: 0, transform: 'translateY(16px)' })
					: null,
			);
		}
	};

	document.addEventListener('astro:page-load', init);
</script>
