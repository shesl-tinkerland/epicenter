---
import { Font } from 'astro:assets';
import { VERSION } from '@epicenter/constants/versions';
import {
	Apple as AppleIcon,
	Check as CheckIcon,
	FileText as FileTextIcon,
	Folder as FolderIcon,
	Globe as GlobeIcon,
	Lightbulb as LightbulbIcon,
	Lock as LockIcon,
	Mic as MicIcon,
	Monitor as MonitorIcon,
	Terminal as TerminalIcon,
	Zap as ZapIcon,
} from '@lucide/astro';
import AppPageHeader from '../components/ecosystem/AppPageHeader.astro';
import AppSwitcher from '../components/ecosystem/AppSwitcher.astro';
import { getApp } from '../lib/apps';
import BaseLayout from '../layouts/BaseLayout.astro';

const app = getApp('whispering')!;
const year = new Date().getFullYear();
const releasesUrl = 'https://github.com/EpicenterHQ/epicenter/releases/latest';
const githubUrl = 'https://github.com/EpicenterHQ/epicenter';
const discordUrl = 'https://go.epicenter.so/discord';
const webUrl = 'https://whispering.epicenter.so';

const features = [
	{
		icon: MicIcon,
		title: 'Hold a key, speak',
		description: 'A shortcut from anywhere on your system. Release, and the words type themselves at your cursor.',
	},
	{
		icon: ZapIcon,
		title: 'Your choice of engine',
		description: 'Fast and cheap in the cloud (Groq, OpenAI, ElevenLabs) or fully local and offline with Speaches.',
	},
	{
		icon: LightbulbIcon,
		title: 'Clean up as you go',
		description: 'Optional AI steps fix grammar, reformat, or run a custom workflow on what you just said.',
	},
	{
		icon: LockIcon,
		title: 'No middleman',
		description: 'Audio goes straight to the provider on your own API key, or never leaves your machine at all.',
	},
];

const pricing = [
	{ provider: 'Groq (Distil)', perHour: '$0.02', light: '$0.20/mo', heavy: '$1.80/mo' },
	{ provider: 'Groq (Large)', perHour: '$0.04', light: '$0.40/mo', heavy: '$3.60/mo' },
	{ provider: 'Local (Speaches)', perHour: '$0.00', light: 'Free', heavy: 'Free' },
];

const downloads = [
	{ platform: 'macOS', icon: AppleIcon, primary: { label: 'Apple Silicon', url: `https://github.com/EpicenterHQ/epicenter/releases/download/v${VERSION}/Whispering_${VERSION}_aarch64.dmg` }, secondary: { label: 'Intel', url: `https://github.com/EpicenterHQ/epicenter/releases/download/v${VERSION}/Whispering_${VERSION}_x64.dmg` } },
	{ platform: 'Windows', icon: MonitorIcon, primary: { label: 'Download .msi', url: `https://github.com/EpicenterHQ/epicenter/releases/download/v${VERSION}/Whispering_${VERSION}_x64_en-US.msi` } },
	{ platform: 'Linux', icon: TerminalIcon, primary: { label: 'View releases', url: releasesUrl } },
	{ platform: 'Web app', icon: GlobeIcon, primary: { label: 'Open in browser', url: webUrl } },
];

const faq = [
	{
		q: 'Can I use it completely free?',
		a: 'Yes. Run Speaches for fully local transcription with no internet and no API keys, or use a provider\'s free tier. Many people never pay anything, and the app itself is free and open source forever.',
	},
	{
		q: 'Where does my audio go?',
		a: 'Local models keep everything on your machine. Cloud models send audio straight to the provider using your own API key. There is no Whispering server in the middle collecting anything.',
	},
	{
		q: 'How is this different from other transcription apps?',
		a: 'Most are closed-source and charge a subscription on top of the provider cost. Whispering is open source: read the code, trace your data, and pay providers directly at cost.',
	},
	{
		q: 'Which providers are supported?',
		a: 'Cloud: Groq (fastest and cheapest), OpenAI Whisper, and ElevenLabs. Local: Speaches, fully offline. More are added based on what people ask for.',
	},
];
---

<BaseLayout
	title="Whispering: talk instead of type"
	description="Whispering is a free, open-source speech-to-text app. Hold a key, speak, and the words land wherever your cursor is. Everything you capture saves as a plain file in a folder you own. macOS, Windows, and Linux."
>
	<Fragment slot="head">
		<Font cssVariable="--font-fraunces" preload />
	</Fragment>

	<main class="page">
		<AppSwitcher />

		<AppPageHeader app={app}>
			<Fragment slot="action">
				<a class="cta cta-solid" data-download href={releasesUrl}>
					Download Whispering, free
				</a>
				<a class="cta cta-quiet" href={webUrl}>Try it in your browser</a>
				<p class="fineprint">Free and open source. macOS, Windows, and Linux.</p>
			</Fragment>
		</AppPageHeader>

		<!-- The capture demo: speak on the left, a file lands on the right -->
		<section>
			<div class="mx-auto max-w-3xl px-6 pb-24 md:pb-28">
				<figure class="cap reveal w-full">
					<div class="cap-panel cap-mic">
						<div class="cap-rec"><span class="cap-dot"></span> Listening</div>
						<p class="cap-text" data-typed>
							Just left the office, traffic is slow on the bridge. I should be
							there by seven.
						</p>
					</div>
					<div class="cap-arrow" aria-hidden="true">&#8594;</div>
					<div class="cap-panel demo-window">
						<div class="demo-titlebar">
							<span class="demo-dot"></span><span class="demo-dot"></span
							><span class="demo-dot"></span>
							<span class="demo-title">my-brain</span>
						</div>
						<div class="ns-tree">
							<div class="ns-row"><FolderIcon /> whispering/</div>
							<div class="ns-row i1 ns-file cap-file">
								<FileTextIcon /> standup.md
							</div>
						</div>
					</div>
				</figure>
				<p class="cap-caption mono-caption mt-6 text-center">
					Hold your shortcut and speak.
				</p>
			</div>
		</section>

		<!-- It types into whatever app you're in -->
		<section class="band">
			<div class="mx-auto max-w-4xl px-6 py-24 text-center md:py-32">
				<p class="eyebrow reveal">Works where you already work</p>
				<h2 class="font-display reveal mt-4 text-balance">
					It types into whatever app you're in.
				</h2>
				<p class="sub reveal mx-auto mt-6 max-w-2xl">
					No special window, no copy-paste. Hold your shortcut, talk, and the
					words land at your cursor: email, docs, chat, your editor.
				</p>
				<figure class="reveal mx-auto mt-12 w-full max-w-xl text-left">
					<div class="demo-window">
						<div class="demo-titlebar">
							<span class="demo-dot"></span><span class="demo-dot"></span
							><span class="demo-dot"></span>
							<span class="demo-title">New Message</span>
						</div>
						<div class="demo-field"><span>To:</span> Sam</div>
						<div class="demo-field"><span>Subject:</span> Running late</div>
						<p class="demo-body" data-typed>
							Just left the office, traffic is slow on the bridge. I should be
							there by seven. Want me to grab dinner on the way?
						</p>
						<div class="demo-hint">
							<span class="demo-mic"></span>
							<span
								>Hold your shortcut and talk. Release, and the words type
								themselves.</span
							>
						</div>
					</div>
					<figcaption class="fineprint mt-3 text-center">
						Simulated. It works the same in any text field.
					</figcaption>
				</figure>
			</div>
		</section>

		<!-- Why: no black box -->
		<section>
			<div class="mx-auto max-w-4xl px-6 py-24 md:py-32">
				<div class="grid items-center gap-12 lg:grid-cols-2">
					<div>
						<h2 class="font-display reveal text-balance">
							Transcription without the black box.
						</h2>
						<p class="sub reveal mt-6">
							Most transcription apps are closed-source and charge a monthly
							markup on top of the real cost. Whispering is open: see the code,
							trace your data, and pay providers directly.
						</p>
						<ul class="why-list reveal mt-8">
							<li><CheckIcon /> Use your own API keys</li>
							<li><CheckIcon /> Pay providers directly, at cost</li>
							<li><CheckIcon /> Or run fully local, for free</li>
						</ul>
					</div>
					<div class="cost-card reveal">
						<div class="cost-big font-display">$0&ndash;5</div>
						<div class="cost-unit">per month, typical use</div>
						<div class="cost-was">instead of $10&ndash;30/mo for a subscription</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Features -->
		<section class="band">
			<div class="mx-auto max-w-5xl px-6 py-24 md:py-32">
				<h2 class="font-display reveal text-center text-balance">
					Everything you need, nothing you don't.
				</h2>
				<div class="grid reveal mt-12 gap-5 sm:grid-cols-2">
					{
						features.map((f) => {
							const Icon = f.icon;
							return (
								<div class="feature">
									<span class="feature-icon"><Icon /></span>
									<h3 class="font-display feature-title">{f.title}</h3>
									<p class="feature-desc">{f.description}</p>
								</div>
							);
						})
					}
				</div>
			</div>
		</section>

		<!-- Pricing -->
		<section id="pricing">
			<div class="mx-auto max-w-3xl px-6 py-24 text-center md:py-32">
				<p class="eyebrow reveal">How is it free?</p>
				<h2 class="font-display reveal mt-4 text-balance">
					You pay the engine, not us.
				</h2>
				<p class="sub reveal mx-auto mt-6 max-w-2xl">
					The app is free and open source. If you use a cloud model, you pay that
					provider directly, usually cents per hour. If you use a local model, you
					pay nothing at all.
				</p>
				<div class="price-card reveal mt-10 text-left">
					<table class="price-table">
						<thead>
							<tr><th>Provider</th><th>Per hour</th><th>Light use</th><th>Heavy use</th></tr>
						</thead>
						<tbody>
							{
								pricing.map((row) => (
									<tr>
										<td>{row.provider}</td>
										<td class="price-strong">{row.perHour}</td>
										<td>{row.light}</td>
										<td>{row.heavy}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>
			</div>
		</section>

		<!-- Sync (moved off root): optional, self-host or hosted -->
		<section class="band">
			<div class="mx-auto max-w-3xl px-6 py-24 text-center md:py-32">
				<p class="eyebrow reveal">Sync, when you want it</p>
				<h2 class="font-display reveal mt-4 text-balance">
					Your folder on every device.
				</h2>
				<p class="sub reveal mx-auto mt-6 max-w-2xl">
					Sync is optional and off by default. Turn it on and your folder appears
					on every device, encrypted so only you can read it. The sync server is
					open source, so you can run it yourself and hold your own keys, or let
					us run it for you.
				</p>
				<p class="reveal mt-8">
					<a class="cta cta-outline" href={githubUrl}>Self-host the sync server</a>
				</p>
			</div>
		</section>

		<!-- Download -->
		<section id="download">
			<div class="mx-auto max-w-5xl px-6 py-24 md:py-32">
				<h2 class="font-display reveal text-center text-balance">
					Download Whispering.
				</h2>
				<p class="sub reveal mx-auto mt-5 max-w-xl text-center">
					Free, open source, and ready tonight.
				</p>
				<div class="grid reveal mt-12 gap-5 sm:grid-cols-2 lg:grid-cols-4">
					{
						downloads.map((d) => {
							const Icon = d.icon;
							return (
								<div class="dl">
									<span class="dl-icon"><Icon /></span>
									<h3 class="font-display dl-name">{d.platform}</h3>
									<a class="cta cta-solid dl-cta" href={d.primary.url}>
										{d.primary.label}
									</a>
									{d.secondary && (
										<a class="dl-secondary" href={d.secondary.url}>
											{d.secondary.label}
										</a>
									)}
								</div>
							);
						})
					}
				</div>
				<p class="fineprint mt-10 text-center">
					Version {VERSION} &middot; about 22MB &middot;
					<a class="nav-link" href={releasesUrl}>all releases</a>
				</p>
			</div>
		</section>

		<!-- FAQ -->
		<section class="band">
			<div class="mx-auto max-w-3xl px-6 py-24 md:py-32">
				<h2 class="font-display reveal text-center text-balance">
					Common questions.
				</h2>
				<div class="reveal mt-12 flex flex-col gap-3">
					{
						faq.map((item) => (
							<details class="faq">
								<summary>{item.q}</summary>
								<p>{item.a}</p>
							</details>
						))
					}
				</div>
			</div>
		</section>

		<footer class="band footer-band">
			<div
				class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 py-12 text-sm md:flex-row"
			>
				<p class="fineprint">
					© {year} Epicenter. Open source under the AGPL-3.0 license.
				</p>
				<div class="flex flex-wrap justify-center gap-x-7 gap-y-3">
					<a class="nav-link" href="/">Epicenter</a>
					<a class="nav-link" href={app.repo}>Source</a>
					<a class="nav-link" href={githubUrl}>GitHub</a>
					<a class="nav-link" href={discordUrl}>Discord</a>
				</div>
			</div>
		</footer>
	</main>
</BaseLayout>

<script is:inline define:vars={{ version: VERSION }}>
	document.addEventListener('astro:page-load', () => {
		const motionOK = matchMedia(
			'(prefers-reduced-motion: no-preference)',
		).matches;

		// OS-detected download. The static href already points at the releases
		// page, so this only ever upgrades the link.
		const ua = navigator.userAgent.toLowerCase();
		const asset = (file) =>
			`https://github.com/EpicenterHQ/epicenter/releases/download/v${version}/${file}`;
		let downloadHref = null;
		if (ua.includes('mac'))
			downloadHref = asset(`Whispering_${version}_aarch64.dmg`);
		else if (ua.includes('win'))
			downloadHref = asset(`Whispering_${version}_x64_en-US.msi`);
		if (downloadHref)
			for (const a of document.querySelectorAll('a[data-download]'))
				a.href = downloadHref;

		// CSS hides animated elements; JS reveals them. Run fn once, when seen.
		const inView = (el, fn, threshold = 0.15) => {
			if (!el) return;
			const io = new IntersectionObserver(
				(entries) => {
					if (entries.some((e) => e.isIntersecting)) {
						io.disconnect();
						fn();
					}
				},
				{ threshold },
			);
			io.observe(el);
		};

		const reveal = (el, from, ms = 600) =>
			el.animate([from, { opacity: 1, filter: 'none', transform: 'none' }], {
				duration: ms,
				easing: 'cubic-bezier(0.2, 0.6, 0.2, 1)',
				fill: 'forwards',
			});

		// Type a sentence into el, character by character.
		const type = (el, done) => {
			const text =
				el.getAttribute('data-text') ||
				el.textContent.trim().replace(/\s+/g, ' ');
			el.setAttribute('data-text', text);
			if (!motionOK) {
				el.textContent = text;
				done && done();
				return;
			}
			el.classList.add('typing');
			el.textContent = '';
			let i = 0;
			const tick = () => {
				el.textContent = text.slice(0, (i += 1));
				if (i < text.length) setTimeout(tick, 36 + Math.random() * 44);
				else {
					el.classList.remove('typing');
					done && done();
				}
			};
			tick();
		};

		for (const el of document.querySelectorAll('.reveal'))
			inView(el, () =>
				motionOK
					? reveal(el, { opacity: 0, transform: 'translateY(16px)' })
					: null,
			);

		// Capture demo: speak, and the words become a file you own.
		const capText = document.querySelector('.cap-text[data-typed]');
		if (capText) {
			const file = document.querySelector('.cap-file');
			const rec = document.querySelector('.cap-rec');
			const caption = document.querySelector('.cap-caption');
			inView(capText.closest('.cap'), () => {
				if (motionOK && rec) rec.classList.add('on');
				type(capText, () => {
					rec && rec.classList.remove('on');
					if (caption)
						caption.textContent = 'Release. The words become a file you own.';
					if (file && motionOK)
						reveal(file, { opacity: 0, transform: 'translateX(-16px)' });
				});
			}, 0.4);
		}

		// Anywhere section: the email types itself when scrolled into view.
		const email = document.querySelector('.demo-body[data-typed]');
		if (email) inView(email, () => type(email), 0.4);
	});
</script>

<style>
	/* Capture demo (speak -> file) */
	.cap {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		gap: clamp(0.8rem, 3vw, 2rem);
		align-items: center;
	}

	.cap-panel {
		background: #fffdf8;
		border: 1px solid var(--line);
		border-radius: 14px;
	}

	.cap-mic {
		padding: 1.2rem 1.3rem;
		box-shadow: 0 12px 32px rgb(38 34 26 / 8%);
		text-align: left;
	}

	.cap-rec {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.78rem;
		color: var(--ink-soft);
		margin-bottom: 0.7rem;
	}

	.cap-dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--line);
	}

	.cap-rec.on .cap-dot {
		background: var(--accent);
		animation: pulse 1.4s ease-in-out infinite;
	}

	.cap-text {
		font-size: 1rem;
		line-height: 1.6;
		min-height: 5rem;
	}

	.cap-arrow {
		font-size: 1.7rem;
		color: var(--ink-soft);
	}

	.cap-file {
		background: rgb(188 63 29 / 7%);
		border-radius: 5px;
	}

	@keyframes pulse {
		50% {
			opacity: 0.35;
		}
	}

	/* Email demo */
	.demo-field {
		padding: 0.55rem 1.1rem;
		border-bottom: 1px solid var(--line);
		font-size: 0.9rem;
	}

	.demo-field span {
		color: var(--ink-soft);
		margin-right: 0.35rem;
	}

	.demo-body {
		padding: 1.1rem;
		min-height: 6.5rem;
		font-size: 1rem;
		line-height: 1.6;
	}

	.demo-body.typing::after,
	.cap-text.typing::after {
		content: "";
		display: inline-block;
		width: 2px;
		height: 1em;
		margin-left: 2px;
		vertical-align: -0.15em;
		background: var(--accent);
		animation: blink 1s steps(1) infinite;
	}

	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	.demo-hint {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.7rem 1.1rem;
		border-top: 1px solid var(--line);
		font-size: 0.8rem;
		color: var(--ink-soft);
	}

	.demo-mic {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--accent);
		animation: pulse 1.6s ease-in-out infinite;
	}

	/* Why list + cost card */
	.why-list {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		font-size: 1.05rem;
	}

	.why-list li {
		display: flex;
		align-items: center;
		gap: 0.7rem;
	}

	.why-list :global(svg) {
		width: 1.2rem;
		height: 1.2rem;
		color: var(--accent);
		flex: none;
	}

	.cost-card {
		background: #fffdf8;
		border: 1px solid var(--line);
		border-radius: 16px;
		padding: 2.5rem;
		text-align: center;
		box-shadow: 0 12px 32px rgb(38 34 26 / 8%);
	}

	.cost-big {
		font-size: 3.5rem;
		font-weight: 600;
		color: var(--accent-deep);
		line-height: 1;
	}

	.cost-unit {
		margin-top: 0.5rem;
		color: var(--ink);
	}

	.cost-was {
		margin-top: 0.75rem;
		font-size: 0.9rem;
		color: var(--ink-soft);
		text-decoration: line-through;
	}

	/* Features */
	.feature {
		background: #fffdf8;
		border: 1px solid var(--line);
		border-radius: 16px;
		padding: 1.6rem;
	}

	.feature-icon :global(svg) {
		width: 1.6rem;
		height: 1.6rem;
		color: var(--accent);
	}

	.feature-title {
		margin-top: 0.8rem;
		font-size: 1.25rem;
		font-weight: 600;
	}

	.feature-desc {
		margin-top: 0.5rem;
		color: var(--ink-soft);
		line-height: 1.55;
	}

	/* Pricing table */
	.price-card {
		background: #fffdf8;
		border: 1px solid var(--line);
		border-radius: 16px;
		overflow: hidden;
	}

	.price-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.95rem;
	}

	.price-table th {
		text-align: left;
		padding: 1rem 1.2rem;
		background: var(--paper-deep);
		font-weight: 600;
		font-size: 0.85rem;
	}

	.price-table td {
		padding: 1rem 1.2rem;
		border-top: 1px solid var(--line);
		color: var(--ink-soft);
	}

	.price-strong {
		color: var(--ink);
		font-weight: 600;
		font-size: 1.05rem;
	}

	/* Downloads */
	.dl {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6rem;
		background: #fffdf8;
		border: 1px solid var(--line);
		border-radius: 16px;
		padding: 1.6rem 1.2rem;
		text-align: center;
	}

	.dl-icon :global(svg) {
		width: 1.8rem;
		height: 1.8rem;
		color: var(--accent);
	}

	.dl-name {
		font-size: 1.2rem;
		font-weight: 600;
	}

	.dl-cta {
		margin-top: 0.4rem;
		width: 100%;
		padding: 0.7rem 1rem;
		font-size: 0.9rem;
	}

	.dl-secondary {
		font-size: 0.85rem;
