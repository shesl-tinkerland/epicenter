---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Page Not Found"
	description="This page doesn't exist. The rest of Epicenter does."
>
	<main
		class="flex min-h-screen flex-col items-center justify-center px-4 text-center"
	>
		<h1 class="text-4xl font-bold">404</h1>
		<p class="text-muted-foreground mt-2 text-lg">Page not found.</p>
		<a
			href="/"
			class="mt-6 text-sm underline underline-offset-4 hover:opacity-80"
			>Back to home</a
		>
	</main>
</BaseLayout>
