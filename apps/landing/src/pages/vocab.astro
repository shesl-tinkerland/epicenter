---
import { Font } from 'astro:assets';
import AppFooter from '../components/ecosystem/AppFooter.astro';
import AppPageHeader from '../components/ecosystem/AppPageHeader.astro';
import AppSwitcher from '../components/ecosystem/AppSwitcher.astro';
import { getApp } from '../lib/apps';
import BaseLayout from '../layouts/BaseLayout.astro';

const app = getApp('vocab')!;
---

<BaseLayout
	title="Vocab: build your vocabulary, a word at a time"
	description="Vocab is a planned Epicenter app: a focused way to study GRE, English, and Zhongwen words, saving every word you learn as ordinary files in a folder you own."
>
	<Fragment slot="head">
		<Font cssVariable="--font-fraunces" preload />
	</Fragment>

	<main class="page">
		<AppSwitcher />
		<AppPageHeader app={app}>
			<Fragment slot="action">
				<a class="cta cta-outline" href={app.repo}>See the Zhongwen experiment</a>
			</Fragment>
		</AppPageHeader>

		<section class="mx-auto grid max-w-5xl gap-10 px-6 pb-24 md:grid-cols-[1.05fr_0.95fr] md:items-center md:pb-32">
			<div class="prose-body">
				<p class="eyebrow">Planned</p>
				<h2 class="font-display mt-4">A vocabulary trail from the words you actually meet.</h2>
				<p>
					Vocab is a planned Epicenter app, not a product you can install. The
					vision is simple: when a word shows up in reading, GRE prep, or a
					Zhongwen conversation, save it into a file you can keep studying from.
				</p>
				<p>
					The seed is Zhongwen, an early Chinese-English chat experiment in the
					repo. Vocab would keep that learning loop, but make the thing you save
					smaller: one word, one note, one language folder.
				</p>
				<p>
					Like the rest of Epicenter, the point is ownership. A word you learn
					should become something you can grep, review, edit, or carry into
					another tool.
				</p>
				<p class="status-note">
					There is no Vocab app code yet. The honest artifact today is the
					Zhongwen experiment it may grow from.
				</p>
			</div>

			<div
				class="vocab-card demo-window"
				aria-label="English and Zhongwen vocabulary words saved as Markdown files"
			>
				<div class="demo-titlebar">
					<span class="demo-dot"></span><span class="demo-dot"></span
					><span class="demo-dot"></span>
					<span class="demo-title">planned sketch</span>
				</div>
				<div class="vocab-body">
					<div class="capture-stack">
						<div class="capture-card">
							<p class="source-label">GRE note</p>
							<p class="capture-text">The witness stayed obdurate.</p>
							<div class="word-chip">
								<span>obdurate</span>
								<small>stubborn</small>
							</div>
						</div>
						<div class="capture-card quiet-card">
							<p class="source-label">Zhongwen chat</p>
							<p class="capture-text">Review this after class: fuxi.</p>
							<div class="word-chip">
								<span>fuxi</span>
								<small>review</small>
							</div>
						</div>
					</div>
					<div class="save-arrow" aria-hidden="true">
						<span></span><span></span>
					</div>
					<div class="file-shelf">
						<div class="vocab-file">
							<p class="file-path">vocab/english.md</p>
							<p><strong>obdurate</strong>: stubbornly refusing to change</p>
							<p class="muted">Saved from reading</p>
						</div>
						<div class="vocab-file">
							<p class="file-path">vocab/zhongwen.md</p>
							<p><strong>fuxi</strong>: review</p>
							<p class="muted">Saved from Zhongwen</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<AppFooter sourceHref={app.repo} sourceLabel="Zhongwen experiment" />
	</main>
</BaseLayout>

<style>
	.prose-body {
		font-size: 1.15rem;
		line-height: 1.8;
		color: var(--ink);
	}

	.prose-body h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		letter-spacing: 0;
	}

	.prose-body p + p {
		margin-top: 1.1rem;
	}

	.status-note {
		margin-top: 1.6rem;
		color: var(--ink-soft);
	}

	.vocab-card {
		max-width: 28rem;
		margin-inline: auto;
		opacity: 0.96;
	}

	.vocab-body {
		padding: 1.1rem;
		background:
			linear-gradient(180deg, #fffdf8, rgb(250 245 236 / 86%)),
			radial-gradient(circle at 80% 12%, rgb(188 63 29 / 10%), transparent 34%);
	}

	.capture-stack {
		display: grid;
		gap: 0.8rem;
	}

	.capture-card {
		border: 1px solid var(--line);
		border-radius: 14px;
		background: var(--paper);
		padding: 0.85rem;
		color: var(--ink);
		line-height: 1.5;
	}

	.quiet-card {
		margin-left: 2rem;
		background: #fffaf0;
	}

	.source-label {
		margin-bottom: 0.35rem;
		font-family: ui-monospace, "SF Mono", Menlo, monospace;
		font-size: 0.72rem;
		text-transform: uppercase;
		color: var(--ink-soft);
	}

	.capture-text {
		font-size: 0.92rem;
	}

	.word-chip {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.65rem;
		border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--line));
		border-radius: 999px;
		background: #fffdf8;
		padding: 0.5rem 0.8rem;
		color: var(--accent-deep);
		box-shadow: 0 8px 22px rgb(38 34 26 / 8%);
	}

	.word-chip span {
		font-weight: 700;
	}

	.word-chip small {
		color: var(--ink-soft);
	}

	.save-arrow {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		width: 72%;
		margin: 0.75rem auto;
		opacity: 0.55;
	}

	.save-arrow span {
		height: 2rem;
		border-right: 1px solid var(--accent);
	}

	.file-shelf {
		display: grid;
		gap: 0.75rem;
	}

	.vocab-file {
		border: 1px solid var(--line);
		border-radius: 12px;
		background: #fffdf8;
		padding: 1rem;
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--ink);
	}

	.file-path {
		margin-bottom: 0.75rem;
		font-family: ui-monospace, "SF Mono", Menlo, monospace;
		font-size: 0.8rem;
		color: var(--accent-deep);
	}

	.muted {
		color: var(--ink-soft);
	}

	@media (max-width: 720px) {
		.quiet-card {
			margin-left: 0;
		}

		.save-arrow {
			width: 58%;
		}
	}
</style>
