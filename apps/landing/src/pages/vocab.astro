---
import { Font } from 'astro:assets';
import AppFooter from '../components/ecosystem/AppFooter.astro';
import AppPageHeader from '../components/ecosystem/AppPageHeader.astro';
import AppSwitcher from '../components/ecosystem/AppSwitcher.astro';
import { getApp } from '../lib/apps';
import BaseLayout from '../layouts/BaseLayout.astro';

const app = getApp('vocab')!;
---

<BaseLayout
	title="Vocab: build your vocabulary, a word at a time"
	description="Vocab is a planned Epicenter app: a focused way to build your vocabulary in any language, saving every word you learn as ordinary files in a folder you own."
>
	<Fragment slot="head">
		<Font cssVariable="--font-fraunces" preload />
	</Fragment>

	<main class="page">
		<AppSwitcher />
		<AppPageHeader app={app}>
			<Fragment slot="action">
				<a class="cta cta-outline" href={app.repo}>See the zhongwen experiment</a>
			</Fragment>
		</AppPageHeader>

		<section class="mx-auto max-w-2xl px-6 pb-28 md:pb-36">
			<div class="prose-body">
				<p>
					Vocab is a focused way to build your vocabulary in another language.
					Meet a new word in conversation, save it, and let it come back to you
					until it sticks.
				</p>
				<p>
					It grows out of an early Chinese-English chat experiment in the repo,
					reshaped around one job: turning the words you encounter into a
					vocabulary you actually keep.
				</p>
				<p>
					Like every Epicenter app, the words you learn land in a folder on your
					computer as plain files, so your vocabulary is yours to keep, export,
					or study with any other tool.
				</p>
				<p class="status-note">
					This is planned, not installable. The closest thing in the repo today
					is the zhongwen experiment it will grow from.
				</p>
			</div>
		</section>

		<AppFooter sourceHref={app.repo} sourceLabel="Zhongwen experiment" />
	</main>
</BaseLayout>

<style>
	.prose-body {
		font-size: 1.15rem;
		line-height: 1.8;
		color: var(--ink);
	}

	.prose-body p + p {
		margin-top: 1.1rem;
	}

	.status-note {
		margin-top: 1.6rem;
		color: var(--ink-soft);
	}
</style>
