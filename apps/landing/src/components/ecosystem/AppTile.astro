---
// One app in the ecosystem grid on the home page. The whole tile routes to
// the app's own page; the status badge carries the honesty. No download here:
// the single "Download now" lives on /whispering.
import type { AppEntry } from '../../lib/apps';
import AppIcon from './AppIcon.astro';
import StatusBadge from './StatusBadge.astro';

type Props = { app: AppEntry };
const { app } = Astro.props;
const cue = app.status === 'live' ? 'Start here' : 'Follow the build';
---

<a href={app.href} class:list={['tile', { featured: app.featured }]}>
	<div class="tile-top">
		<span class="tile-icon"><AppIcon name={app.icon} /></span>
		<StatusBadge status={app.status} />
	</div>
	<h3 class="font-display tile-name">{app.name}</h3>
	<p class="tile-tagline">{app.tagline}</p>
	<span class="tile-cue">{cue} &#8594;</span>
</a>

<style>
	.tile {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.5rem;
		border: 1px solid var(--line);
		border-radius: 16px;
		background: #fffdf8;
		color: var(--ink);
		text-decoration: none;
		box-shadow: 0 1px 2px rgb(38 34 26 / 5%);
		transition:
			transform 160ms ease,
			box-shadow 160ms ease,
			border-color 160ms ease;
	}

	.tile:hover {
		transform: translateY(-3px);
		box-shadow: 0 12px 28px rgb(38 34 26 / 10%);
		border-color: color-mix(in srgb, var(--accent) 35%, var(--line));
	}

	.tile.featured {
		border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
		box-shadow: 0 2px 0 color-mix(in srgb, var(--accent) 25%, var(--line));
	}

	.tile-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.tile-icon :global(svg) {
		width: 1.6rem;
		height: 1.6rem;
		color: var(--accent);
	}

	.tile-name {
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.tile-tagline {
		font-size: 0.95rem;
		line-height: 1.5;
		color: var(--ink-soft);
		flex: 1;
	}

	.tile-cue {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--accent-deep);
	}

	.tile:hover .tile-cue {
		color: var(--accent);
	}
</style>
