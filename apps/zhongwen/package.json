{
	"name": "@epicenter/zhongwen",
	"description": "Bilingual Chinese-English chat app for learning Mandarin",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"exports": {
		"./workspace": "./src/lib/workspace/index.ts",
		"./openZhongwen": "./src/lib/zhongwen/index.ts",
		"./browser": "./src/lib/zhongwen/browser.ts",
		"./daemon": "./src/lib/zhongwen/daemon.ts",
		"./script": "./src/lib/zhongwen/script.ts"
	},
	"scripts": {
		"dev": "bun run dev:local",
		"dev:local": "bun --bun vite dev",
		"dev:remote": "bun --bun vite dev --mode production",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"test": "bun test ./src/lib/zhongwen",
		"typecheck": "svelte-check",
		"deploy": "bun run build && wrangler deploy"
	},
	"dependencies": {
		"@epicenter/auth-svelte": "workspace:*",
		"@epicenter/constants": "workspace:*",
		"@epicenter/svelte": "workspace:*",
		"@epicenter/ui": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@lucide/svelte": "catalog:",
		"@tanstack/ai": "catalog:",
		"@tanstack/ai-anthropic": "catalog:",
		"@tanstack/ai-client": "^0.7.2",
		"@tanstack/ai-gemini": "catalog:",
		"@tanstack/ai-grok": "catalog:",
		"@tanstack/ai-openai": "catalog:",
		"arktype": "catalog:",
		"dompurify": "^3.3.3",
		"marked": "^17.0.5",
		"mode-watcher": "^1.1.0",
		"pinyin-pro": "^3.28.0",
		"svelte-sonner": "catalog:",
		"wellcrafted": "catalog:",
		"yjs": "catalog:"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/dompurify": "^3.2.0",
		"@types/node": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:"
	},
	"license": "MIT"
}
