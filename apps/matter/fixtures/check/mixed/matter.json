{
	"fields": {
		"title": { "type": "string", "minLength": 1 },
		"status": { "enum": ["draft", "ready", "published"] },
		"duration": { "type": "integer" },
		"url": { "type": "string", "format": "uri" },
		"destinations": {
			"type": "array",
			"items": { "enum": ["linkedin", "x", "newsletter"] }
		},
		"published": { "type": "boolean" }
	},
	"optional": ["url", "destinations", "published"]
}
