{
	"name": "@epicenter/matter",
	"description": "Typed markdown folder editor: open a folder, give it a model, see files grouped by conformance (valid / invalid / unparseable).",
	"private": true,
	"version": "0.0.2",
	"type": "module",
	"scripts": {
		"dev": "bun run dev:local",
		"dev:local": "bun tauri dev --config '{\"identifier\": \"so.epicenter.matter.dev\"}'",
		"dev:web": "vite dev",
		"dev:fixture": "bun scripts/dev-fixture.ts",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "bun src/cli/check.ts",
		"tauri": "tauri",
		"test": "bun test",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"devDependencies": {
		"@epicenter/ui": "workspace:*",
		"@lucide/svelte": "catalog:",
		"@sveltejs/adapter-static": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@tauri-apps/cli": "catalog:",
		"@types/bun": "catalog:",
		"mode-watcher": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/search": "^6.6.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.0",
		"@epicenter/field": "workspace:*",
		"@epicenter/svelte": "workspace:*",
		"@lezer/common": "^1.5.1",
		"@lezer/highlight": "^1.2.3",
		"@replit/codemirror-vim": "^6.3.0",
		"@tauri-apps/api": "catalog:",
		"@tauri-apps/plugin-dialog": "^2.3.2",
		"arktype": "catalog:",
		"typebox": "catalog:",
		"wellcrafted": "catalog:",
		"yaml": "^2.8.0"
	},
	"license": "AGPL-3.0-or-later"
}
