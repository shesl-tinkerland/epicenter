{
	"name": "@epicenter/tab-manager",
	"description": "Browser extension for managing tabs with workspace sync and AI chat",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"exports": {
		"./workspace": "./src/lib/workspace/index.ts"
	},
	"scripts": {
		"dev": "bun run dev:local",
		"dev:local": "wxt",
		"dev:remote": "wxt --mode production",
		"build": "wxt build",
		"zip": "wxt zip",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"postinstall": "wxt prepare"
	},
	"dependencies": {
		"@epicenter/auth": "workspace:*",
		"@epicenter/auth-svelte": "workspace:*",
		"@epicenter/constants": "workspace:*",
		"@epicenter/svelte": "workspace:*",
		"@epicenter/ui": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@lucide/svelte": "catalog:",
		"@tanstack/ai": "catalog:",
		"@tanstack/ai-anthropic": "catalog:",
		"@tanstack/ai-client": "^0.7.2",
		"@tanstack/ai-gemini": "catalog:",
		"@tanstack/ai-grok": "catalog:",
		"@tanstack/ai-openai": "catalog:",
		"@tanstack/ai-svelte": "^0.6.7",
		"@wxt-dev/storage": "^1.2.6",
		"arktype": "catalog:",
		"better-auth": "catalog:",
		"clsx": "catalog:",
		"dompurify": "^3.3.3",
		"marked": "catalog:",
		"mode-watcher": "^1.1.0",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "catalog:",
		"typebox": "catalog:",
		"virtua": "catalog:",
		"wellcrafted": "catalog:",
		"y-indexeddb": "catalog:",
		"yjs": "catalog:"
	},
	"devDependencies": {
		"@standard-schema/spec": "catalog:",
		"@epicenter/api": "workspace:*",
		"@tailwindcss/vite": "catalog:",
		"@types/node": "catalog:",
		"@wxt-dev/module-svelte": "^2.0.3",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"wxt": "^0.20.8"
	},
	"license": "MIT"
}
