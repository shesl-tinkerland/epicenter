{
	"name": "@epicenter/whispering",
	"private": true,
	"version": "7.11.1",
	"description": "Desktop and web speech-to-text with global shortcuts and AI transformations",
	"exports": {
		"./commands": "./src/lib/commands.ts",
		"./workspace": "./src/lib/workspace/index.ts"
	},
	"imports": {
		"#platform/commands": {
			"tauri": "./src/lib/commands.tauri.ts",
			"default": "./src/lib/commands.browser.ts"
		},
		"#platform/analytics": {
			"tauri": "./src/lib/services/analytics/index.tauri.ts",
			"default": "./src/lib/services/analytics/index.browser.ts"
		},
		"#platform/blob-store": {
			"tauri": "./src/lib/services/blob-store/index.tauri.ts",
			"default": "./src/lib/services/blob-store/index.browser.ts"
		},
		"#platform/download": {
			"tauri": "./src/lib/services/download/index.tauri.ts",
			"default": "./src/lib/services/download/index.browser.ts"
		},
		"#platform/http": {
			"tauri": "./src/lib/services/http/index.tauri.ts",
			"default": "./src/lib/services/http/index.browser.ts"
		},
		"#platform/os": {
			"tauri": "./src/lib/platform/os.tauri.ts",
			"default": "./src/lib/platform/os.browser.ts"
		},
		"#platform/shortcuts": {
			"tauri": "./src/lib/platform/shortcuts.tauri.ts",
			"default": "./src/lib/platform/shortcuts.browser.ts"
		},
		"#platform/recorder": {
			"tauri": "./src/lib/services/recorder/index.tauri.ts",
			"default": "./src/lib/services/recorder/index.browser.ts"
		},
		"#platform/recording-overlay": {
			"tauri": "./src/lib/recording-overlay/index.tauri.ts",
			"default": "./src/lib/recording-overlay/index.browser.ts"
		},
		"#platform/text": {
			"tauri": "./src/lib/services/text/index.tauri.ts",
			"default": "./src/lib/services/text/index.browser.ts"
		},
		"#platform/manual-recorder-config": {
			"tauri": "./src/lib/state/manual-recorder-config.tauri.ts",
			"default": "./src/lib/state/manual-recorder-config.browser.ts"
		},
		"#platform/whispering": {
			"tauri": "./src/lib/whispering/whispering.tauri.ts",
			"default": "./src/lib/whispering/whispering.browser.ts"
		},
		"#platform/tauri": {
			"tauri": "./src/lib/tauri.tauri.ts",
			"default": "./src/lib/tauri.browser.ts"
		},
		"#platform/os-notify": {
			"tauri": "./src/lib/report/os-notify.tauri.ts",
			"default": "./src/lib/report/os-notify.browser.ts"
		}
	},
	"scripts": {
		"dev:web": "vite dev",
		"dev": "bun run dev:local",
		"dev:local": "bun run scripts/launch-dev.ts",
		"dev:doctor": "bun run scripts/dev-doctor.ts",
		"test": "bun test tests/",
		"build": "NODE_ENV=production vite build",
		"check": "bun run typecheck",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"bindings:tauri": "cargo test --manifest-path src-tauri/Cargo.toml export_types",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tauri": "tauri",
		"deploy": "wrangler deploy"
	},
	"license": "AGPL-3.0-or-later",
	"devDependencies": {
		"@epicenter/ui": "workspace:*",
		"@epicenter/vite-config": "workspace:*",
		"@types/bun": "catalog:",
		"@lucide/svelte": "catalog:",
		"@sveltejs/adapter-static": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/typography": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@tauri-apps/cli": "catalog:",
		"@types/js-yaml": "^4.0.9",
		"mode-watcher": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"svelte-sonner": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-static-copy": "^4.1.1",
		"wrangler": "catalog:"
	},
	"type": "module",
	"dependencies": {
		"@anthropic-ai/sdk": "^0.55.0",
		"@aptabase/tauri": "^0.4.1",
		"@aptabase/web": "^0.4.3",
		"@epicenter/constants": "workspace:*",
		"@epicenter/field": "workspace:*",
		"@epicenter/svelte": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@google/generative-ai": "^0.24.1",
		"@mistralai/mistralai": "^1.9.18",
		"@ricky0123/vad-web": "^0.0.30",
		"@standard-schema/spec": "catalog:",
		"@tanstack/svelte-query": "catalog:",
		"@tanstack/svelte-table": "catalog:",
		"@tanstack/table-core": "9.0.0-alpha.10",
		"@tauri-apps/api": "catalog:",
		"@tauri-apps/plugin-autostart": "^2.0.1",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.0",
		"@tauri-apps/plugin-dialog": "^2.3.2",
		"@tauri-apps/plugin-fs": "catalog:",
		"@tauri-apps/plugin-global-shortcut": "^2.3.0",
		"@tauri-apps/plugin-http": "2.5.4",
		"@tauri-apps/plugin-log": "~2",
		"@tauri-apps/plugin-notification": "^2.3.0",
		"@tauri-apps/plugin-opener": "catalog:",
		"@tauri-apps/plugin-os": "^2.3.0",
		"@tauri-apps/plugin-process": "^2.3.0",
		"@tauri-apps/plugin-updater": "^2.9.0",
		"arkregex": "catalog:",
		"arktype": "catalog:",
		"audio-recorder-polyfill": "^0.4.1",
		"bits-ui": "catalog:",
		"date-fns": "catalog:",
		"dexie": "^4.0.11",
		"dompurify": "^3.4.10",
		"elevenlabs": "^1.59.0",
		"fflate": "catalog:",
		"groq-sdk": "^0.25.0",
		"idb": "^8.0.3",
		"js-yaml": "^4.1.1",
		"marked": "catalog:",
		"mime": "catalog:",
		"nanoid": "catalog:",
		"openai": "^5.7.0",
		"tailwind-variants": "catalog:",
		"tauri-plugin-macos-permissions-api": "^2.3.0",
		"typebox": "catalog:",
		"wellcrafted": "catalog:",
		"yjs": "catalog:"
	}
}
