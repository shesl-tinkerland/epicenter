{
	"name": "@epicenter/cli",
	"version": "0.1.0",
	"description": "Introspect and invoke defineQuery/defineMutation actions from configured project mounts.",
	"keywords": [
		"local-first",
		"CLI",
		"epicenter",
		"workspace",
		"CRDT",
		"offline-first",
		"PKM",
		"terminal"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/EpicenterHQ/epicenter.git",
		"directory": "packages/cli"
	},
	"homepage": "https://epicenter.so",
	"exports": {
		".": "./src/index.ts"
	},
	"bin": {
		"epicenter": "./bin/epicenter.mjs"
	},
	"scripts": {
		"cli": "bun src/bin.ts",
		"cli:local": "EPICENTER_API_URL=http://localhost:8787 bun src/bin.ts"
	},
	"dependencies": {
		"@epicenter/auth": "workspace:*",
		"@epicenter/constants": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@hono/standard-validator": "catalog:",
		"arktype": "catalog:",
		"hono": "catalog:",
		"typebox": "catalog:",
		"wellcrafted": "catalog:",
		"yargs": "catalog:",
		"yjs": "catalog:"
	},
	"devDependencies": {
		"@epicenter/api": "workspace:*",
		"@epicenter/honeycrisp": "workspace:*",
		"@epicenter/tab-manager": "workspace:*",
		"@types/bun": "catalog:",
		"@types/yargs": "catalog:",
		"typescript": "catalog:"
	},
	"license": "MIT"
}
