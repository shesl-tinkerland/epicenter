{
	"name": "@epicenter/ui",
	"version": "0.1.0",
	"description": "Svelte 5 UI components for Epicenter apps. Built with shadcn-svelte and Tailwind CSS.",
	"keywords": [
		"svelte",
		"UI",
		"epicenter",
		"components",
		"local-first",
		"CRDT",
		"shadcn",
		"tailwind"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/EpicenterHQ/epicenter.git",
		"directory": "packages/ui"
	},
	"homepage": "https://epicenter.so",
	"type": "module",
	"imports": {
		"#*": [
			"./src/*",
			"./src/*.ts",
			"./src/*/index.ts"
		]
	},
	"exports": {
		"./*": "./src/*/index.ts",
		"./utils": "./src/utils.ts",
		"./utils/*": "./src/utils/*.ts",
		"./app.css": "./src/app.css"
	},
	"scripts": {
		"typecheck": "svelte-check"
	},
	"dependencies": {
		"@fontsource-variable/manrope": "^5.2.6",
		"@lucide/svelte": "catalog:",
		"@tanstack/svelte-table": "catalog:",
		"bits-ui": "catalog:",
		"clsx": "catalog:",
		"paneforge": "^1.0.2",
		"tailwind-merge": "catalog:",
		"tailwind-variants": "catalog:"
	},
	"peerDependencies": {
		"svelte": ">=5.0.0"
	},
	"devDependencies": {
		"@emoji-mart/data": "^1.2.1",
		"@internationalized/date": "^3.10.0",
		"@types/node": "catalog:",
		"jsrepo": "catalog:",
		"layerchart": "2.0.0-next.48",
		"mode-watcher": "catalog:",
		"package-manager-detector": "^1.3.0",
		"runed": "^0.36.0",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"svelte-sonner": "catalog:",
		"svelte-toolbelt": "^0.10.6",
		"tailwindcss": "catalog:",
		"tw-animate-css": "^1.3.5",
		"typescript": "catalog:",
		"vaul-svelte": "^1.0.0-next.7",
		"wellcrafted": "catalog:"
	},
	"license": "MIT"
}
