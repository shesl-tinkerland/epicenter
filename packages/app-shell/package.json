{
	"name": "@epicenter/app-shell",
	"version": "0.3.0",
	"private": true,
	"type": "module",
	"description": "Shared Epicenter app chrome: account popover, workspace gate, and the instance settings surface. Branded, full-stack-aware UI mounted in each app's layout. Private (not published).",
	"keywords": [
		"svelte",
		"epicenter",
		"app-shell"
	],
	"exports": {
		"./account-popover": "./src/account-popover/index.ts",
		"./agent-chat": "./src/agent-chat/index.ts",
		"./inference-picker": "./src/inference-picker/index.ts",
		"./instance-settings": "./src/instance-settings/index.ts",
		"./sign-in-migration": "./src/sign-in-migration/index.ts",
		"./workspace-gate": "./src/workspace-gate/index.ts"
	},
	"scripts": {
		"typecheck": "svelte-check --tsconfig ./tsconfig.json"
	},
	"dependencies": {
		"@epicenter/auth": "workspace:*",
		"@epicenter/chat": "workspace:*",
		"@epicenter/client": "workspace:*",
		"@epicenter/svelte": "workspace:*",
		"@epicenter/ui": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@lucide/svelte": "catalog:",
		"@standard-schema/spec": "catalog:",
		"@tanstack/svelte-query": "catalog:",
		"arktype": "catalog:",
		"wellcrafted": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"typescript": "catalog:"
	},
	"license": "AGPL-3.0-or-later"
}
