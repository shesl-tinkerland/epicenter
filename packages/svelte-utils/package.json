{
	"name": "@epicenter/svelte",
	"version": "0.1.0",
	"type": "module",
	"description": "Svelte 5 utilities for Epicenter workspaces. Reactive state bindings, persisted state, and TanStack Query integration.",
	"keywords": [
		"svelte",
		"local-first",
		"CRDT",
		"epicenter",
		"workspace",
		"TanStack Query",
		"reactive state"
	],
	"exports": {
		".": "./src/index.ts",
		"./auth": "./src/auth/index.ts",
		"./auth-form": "./src/auth-form/index.ts",
		"./workspace-gate": "./src/workspace-gate/index.ts"
	},
	"dependencies": {
		"@epicenter/constants": "workspace:*",
		"@epicenter/api": "workspace:*",
		"@epicenter/ui": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@lucide/svelte": "catalog:",
		"arktype": "catalog:",
		"better-auth": "catalog:",
		"idb": "^8.0.3",
		"wellcrafted": "catalog:"
