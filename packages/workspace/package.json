		"CRDT",
		"epicenter",
		"Yjs",
		"offline-first",
		"SQLite",
		"markdown",
		"personal knowledge base",
		"PKM",
		"second brain",
		"sync",
		"workspace",
		"typed schema"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/EpicenterHQ/epicenter.git",
		"directory": "packages/workspace"
	},
	"homepage": "https://epicenter.so",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
